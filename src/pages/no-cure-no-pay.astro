---
import Layout from '../layouts/Layout.astro';
---

<Layout locale="en" title="No Cure No Pay — ClosersMatch" description="You only pay when we deliver. No fixed salary, no recruitment fees, no long-term contract. No cure no pay is the ClosersMatch promise.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="ncnp-hero">
    <div class="container ncnp-hero__inner">
      <div class="ncnp-hero__content">
        <span class="label label--red">No Cure No Pay</span>
        <h1 class="ncnp-hero__title">
          You only pay<br />
          when we deliver.<br />
          <span class="ncnp-hero__title-red">Period.</span>
        </h1>
        <p class="ncnp-hero__subtitle">
          No fixed salary. No recruitment fees. No long-term contract. No cure no pay is not just a payment model, it is a promise. If we do not perform, you pay nothing. Our success is always aligned with yours.
        </p>
        <div class="ncnp-hero__trust-pills">
          <span class="trust-pill">✓ No upfront costs</span>
          <span class="trust-pill">✓ No long-term contract</span>
          <span class="trust-pill">✓ Pay only for results</span>
        </div>
        <div class="ncnp-hero__actions">
          <a href="/contact" class="btn btn--red btn--lg">Book your free intake →</a>
        </div>
      </div>

      <div class="ncnp-hero__visual">
        <div class="ncnp-hero__pay-card">
          <span class="ncnp-hero__pay-card-label">How you pay</span>
          <div class="ncnp-pay-item">
            <span class="ncnp-pay-item__num">01</span>
            <div>
              <strong>Appointment setter</strong>
              <span>You pay per qualified appointment. Only leads with buying intent make it through.</span>
            </div>
          </div>
          <div class="ncnp-pay-item">
            <span class="ncnp-pay-item__num">02</span>
            <div>
              <strong>Closer</strong>
              <span>You pay only when a deal is closed. No results, no costs.</span>
            </div>
          </div>
          <div class="ncnp-pay-item">
            <span class="ncnp-pay-item__num">03</span>
            <div>
              <strong>Combination</strong>
              <span>Fully outsourced sales journey from first contact to closed deal.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       HET PROBLEEM
  ================================================ -->
  <section class="section ncnp-probleem">
    <div class="container">
      <div class="ncnp-probleem__header">
        <span class="label">Sound familiar?</span>
        <h2 class="h2 ncnp-probleem__title">Generating leads works.<br />Converting them does not.</h2>
        <p class="ncnp-probleem__sub">Creating interest is only the beginning. Opportunities are lost because nobody follows up fast enough, sales conversations lack structure, and prospects never reach the closing stage. The result? Wasted marketing budget. Limited revenue. Unpredictable growth.</p>
      </div>

      <div class="ncnp-probleem__grid">
        <div class="ncnp-probleem__item">
          <div class="ncnp-probleem__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3 class="ncnp-probleem__item-title">Leads not followed up fast enough</h3>
            <p class="ncnp-probleem__item-text">Every day of delay in follow-up drastically reduces the chance of conversion.</p>
          </div>
        </div>
        <div class="ncnp-probleem__item">
          <div class="ncnp-probleem__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <div>
            <h3 class="ncnp-probleem__item-title">Sales conversations without structure or direction</h3>
            <p class="ncnp-probleem__item-text">Without a script or process, every conversation becomes a gamble instead of a system.</p>
          </div>
        </div>
        <div class="ncnp-probleem__item">
          <div class="ncnp-probleem__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <div>
            <h3 class="ncnp-probleem__item-title">Prospects not properly qualified</h3>
            <p class="ncnp-probleem__item-text">Time wasted on leads without buying intent or budget.</p>
          </div>
        </div>
        <div class="ncnp-probleem__item">
          <div class="ncnp-probleem__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <h3 class="ncnp-probleem__item-title">Opportunities that never reach the closing stage</h3>
            <p class="ncnp-probleem__item-text">Warm leads go cold without a deal conversation ever taking place.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAT WE DOEN
  ================================================ -->
  <section class="section ncnp-doen">
    <div class="container">
      <div class="ncnp-doen__header">
        <span class="label label--red">The model</span>
        <h2 class="h2 ncnp-doen__title">From first contact to closed deal.<br />We handle the entire journey.</h2>
      </div>

      <div class="ncnp-doen__grid">
        <div class="ncnp-doen__card">
          <div class="ncnp-doen__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="ncnp-doen__card-title">Schedule appointments</h3>
          <p class="ncnp-doen__card-text">Setters find, reach out to, and qualify potential buyers. Only serious leads land in your calendar.</p>
        </div>
        <div class="ncnp-doen__card">
          <div class="ncnp-doen__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="ncnp-doen__card-title">Professional closing</h3>
          <p class="ncnp-doen__card-text">Certified closers run the conversation, map needs, and close the deal.</p>
        </div>
        <div class="ncnp-doen__card">
          <div class="ncnp-doen__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="ncnp-doen__card-title">Create opportunities</h3>
          <p class="ncnp-doen__card-text">Qualified prospects are nurtured and handed off to the closer at the right moment.</p>
        </div>
        <div class="ncnp-doen__card">
          <div class="ncnp-doen__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="ncnp-doen__card-title">Optimize &amp; scale</h3>
          <p class="ncnp-doen__card-text">Every stage is tracked, improved, and scaled. More data. Better conversion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET MODEL WERKT
  ================================================ -->
  <section class="section ncnp-model">
    <div class="container">
      <div class="ncnp-model__header">
        <span class="label">How you pay</span>
        <h2 class="h2 ncnp-model__title">Three models. One principle:<br />no results, no costs.</h2>
      </div>

      <div class="ncnp-model__grid">
        <div class="ncnp-model__card">
          <div class="ncnp-model__num">01</div>
          <h3 class="ncnp-model__card-title">Appointment setter</h3>
          <p class="ncnp-model__card-text">You pay per qualified appointment placed in your calendar. Only leads with genuine buying intent make it through. No appointment, no cost.</p>
        </div>
        <div class="ncnp-model__card">
          <div class="ncnp-model__num">02</div>
          <h3 class="ncnp-model__card-title">Closer</h3>
          <p class="ncnp-model__card-text">You pay only when a deal is actually closed. The closer runs the conversation, maps needs, and closes. No results, no costs.</p>
        </div>
        <div class="ncnp-model__card ncnp-model__card--featured">
          <span class="ncnp-model__badge">Most popular</span>
          <div class="ncnp-model__num">03</div>
          <h3 class="ncnp-model__card-title">Combination</h3>
          <p class="ncnp-model__card-text">Full sales outsourcing where ClosersMatch manages the complete journey. From first contact and qualification to closing the deal. One system, one accountable partner.</p>
        </div>
      </div>

      <div class="ncnp-model__cta">
        <a href="/contact" class="btn btn--red btn--lg">Book your free intake →</a>
      </div>
    </div>
  </section>

  <!-- ================================================
       VOOR WIE
  ================================================ -->
  <section class="section ncnp-voorwie">
    <div class="container ncnp-voorwie__inner">
      <div class="ncnp-voorwie__content">
        <span class="label">Who it's for</span>
        <h2 class="h2 ncnp-voorwie__title">This model works if you are serious about growth.</h2>
        <p class="ncnp-voorwie__body">This is the right model if you sell high-ticket B2B products or services, prefer performance-based collaboration, and want to grow without expanding headcount.</p>
      </div>

      <div class="ncnp-voorwie__checklist">
        <div class="ncnp-check">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          You sell high-ticket B2B products or services
        </div>
        <div class="ncnp-check">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          You do not want to build or manage an internal sales team
        </div>
        <div class="ncnp-check">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          You have warm leads that are not being closed consistently
        </div>
        <div class="ncnp-check">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          You want scalable sales capacity without hiring risk
        </div>
        <div class="ncnp-check">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          You prefer to pay for results rather than presence
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAT JE KUNT VERWACHTEN
  ================================================ -->
  <section class="section ncnp-resultaten">
    <div class="container">
      <div class="ncnp-resultaten__header">
        <span class="label label--red">Results</span>
        <h2 class="h2 ncnp-resultaten__title">No promises.<br />Measurable outcomes.</h2>
      </div>

      <div class="ncnp-resultaten__grid">
        <div class="ncnp-resultaten__card">
          <div class="ncnp-resultaten__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="ncnp-resultaten__card-title">More qualified meetings</h3>
          <p class="ncnp-resultaten__card-text">A steady stream of serious sales opportunities.</p>
        </div>
        <div class="ncnp-resultaten__card">
          <div class="ncnp-resultaten__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="ncnp-resultaten__card-title">Higher conversion rate</h3>
          <p class="ncnp-resultaten__card-text">More leads that actually reach the closing stage.</p>
        </div>
        <div class="ncnp-resultaten__card">
          <div class="ncnp-resultaten__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="ncnp-resultaten__card-title">Professional sales execution</h3>
          <p class="ncnp-resultaten__card-text">Certified professionals who maximize every opportunity.</p>
        </div>
        <div class="ncnp-resultaten__card">
          <div class="ncnp-resultaten__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="ncnp-resultaten__card-title">Scalable revenue growth</h3>
          <p class="ncnp-resultaten__card-text">A system that grows with your ambitions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="ncnp-closing">
    <div class="ncnp-closing__inner">
      <span class="label label--ghost-light">No cure no pay</span>
      <h2 class="ncnp-closing__title">
        No results?<br />Then you pay nothing.
      </h2>
      <p class="ncnp-closing__body">
        ClosersMatch works exclusively on no cure no pay. Our success depends on your results. That is exactly why it works.
      </p>
      <a href="/contact" class="btn btn--red btn--xl ncnp-closing__btn">Book your free intake →</a>
      <p class="ncnp-closing__sub">No obligations. No upfront costs. Just a clear picture of what is possible.</p>
      <p class="ncnp-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .ncnp-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .ncnp-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .ncnp-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .ncnp-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .ncnp-hero__title-red { color: var(--color-red); }

  .ncnp-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .ncnp-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .ncnp-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Pay card */
  .ncnp-hero__pay-card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
  }

  .ncnp-hero__pay-card-label {
    display: block;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 20px;
  }

  .ncnp-pay-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ncnp-pay-item:last-child { border-bottom: none; padding-bottom: 0; }

  .ncnp-pay-item__num {
    font-size: 0.78rem;
    font-weight: 900;
    color: var(--color-red);
    letter-spacing: 0.04em;
  }

  .ncnp-pay-item strong {
    display: block;
    font-size: 0.98rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
    font-family: var(--font-display);
  }

  .ncnp-pay-item span {
    font-size: 0.83rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.55;
  }

  @media (max-width: 960px) {
    .ncnp-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .ncnp-hero { padding: 100px 0 60px; }
    .ncnp-hero__actions .btn { width: 100%; justify-content: center; }
  }

  /* ====================================================
     PROBLEEM
  ==================================================== */
  .ncnp-probleem { background: #F9FAFB; }

  .ncnp-probleem__header {
    max-width: 700px;
    margin-bottom: 56px;
  }

  .ncnp-probleem__title {
    margin-top: 16px;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .ncnp-probleem__sub {
    font-size: 1.05rem;
    color: var(--color-gray-mid);
    line-height: 1.7;
  }

  .ncnp-probleem__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .ncnp-probleem__item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ncnp-probleem__item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .ncnp-probleem__icon {
    width: 36px;
    height: 36px;
    background: rgba(221,52,46,0.08);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-red);
    flex-shrink: 0;
  }

  .ncnp-probleem__item-title {
    font-size: 0.97rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: 6px;
    font-family: var(--font-display);
  }

  .ncnp-probleem__item-text {
    font-size: 0.88rem;
    color: var(--color-gray-mid);
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .ncnp-probleem__grid { grid-template-columns: 1fr; }
  }

  /* ====================================================
     WAT WE DOEN
  ==================================================== */
  .ncnp-doen { background: #fff; }

  .ncnp-doen__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 56px;
  }

  .ncnp-doen__title {
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .ncnp-doen__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ncnp-doen__card {
    padding: 28px 22px;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    background: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ncnp-doen__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .ncnp-doen__icon {
    width: 44px;
    height: 44px;
    background: rgba(221,52,46,0.08);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-red);
    margin-bottom: 18px;
  }

  .ncnp-doen__card-title {
    font-size: 0.97rem;
    font-weight: 800;
    color: var(--color-black);
    margin-bottom: 8px;
    font-family: var(--font-display);
  }

  .ncnp-doen__card-text {
    font-size: 0.87rem;
    color: var(--color-gray-mid);
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .ncnp-doen__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .ncnp-doen__grid { grid-template-columns: 1fr; }
  }

  /* ====================================================
     HOE HET MODEL WERKT
  ==================================================== */
  .ncnp-model { background: #F9FAFB; }

  .ncnp-model__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  .ncnp-model__title {
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .ncnp-model__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .ncnp-model__card {
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    position: relative;
  }

  .ncnp-model__card--featured {
    border-color: var(--color-red);
    box-shadow: 0 0 0 1px var(--color-red), var(--shadow-lg);
    transform: translateY(-6px);
  }

  .ncnp-model__badge {
    position: absolute;
    top: -13px;
    right: 24px;
    background: var(--color-red);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
  }

  .ncnp-model__num {
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--color-red);
    font-family: var(--font-display);
