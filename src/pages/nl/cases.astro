---
import Layout from '../../layouts/Layout.astro';
---

<Layout locale="nl" title="Klantcases & resultaten — ClosersMatch" description="Geen prognoses. Echte resultaten van echte bedrijven. Ontdek hoe DetachPro, Van de Bilt Energy en Leadstars commercieel succes behaalden via ClosersMatch.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="cs-hero">
    <div class="container cs-hero__inner">
      <div class="cs-hero__content">
        <span class="label label--red">Klantcases &amp; resultaten</span>
        <h1 class="cs-hero__title">
          Resultaten die spreken.<br />
          <span class="cs-hero__title-red">Niet prognoses.</span>
        </h1>
        <p class="cs-hero__subtitle">
          Wij laten de cijfers het woord doen. Geen mooie verhalen over wat er mogelijk is — maar aantoonbare resultaten van echte bedrijven die via ClosersMatch commercieel zijn doorgebroken. Deals gesloten. Omzet gegenereerd. Vanaf week één.
        </p>
        <div class="cs-hero__trust-pills">
          <span class="trust-pill">Ô£ô Bewezen track record</span>
          <span class="trust-pill">Ô£ô Resultaat vanaf week 1</span>
          <span class="trust-pill">Ô£ô No cure no pay</span>
        </div>
        <div class="cs-hero__actions">
          <a href="/nl/contact" class="btn btn--red btn--lg">Plan je gratis intake →</a>
          <a href="#cases" class="btn btn--outline-dark-mode">Bekijk de cases</a>
        </div>
      </div>

      <div class="cs-hero__visual">
        <div class="cs-hero__proof-card">
          <div class="cs-proof-header">Gesloten deals via ClosersMatch</div>
          <div class="cs-proof-item">
            <div class="cs-proof-item__logo-wrap cs-proof-item__logo-wrap--light">
              <img src="/images/clients/detachpro.png" alt="DetachPro" class="cs-proof-item__logo" />
            </div>
            <div class="cs-proof-item__info">
              <span class="cs-proof-item__result">€50.000</span>
              <span class="cs-proof-item__label">Deal gesloten — week 1</span>
            </div>
          </div>
          <div class="cs-proof-divider"></div>
          <div class="cs-proof-item">
            <div class="cs-proof-item__logo-wrap cs-proof-item__logo-wrap--dark">
              <img src="/images/clients/leadstars.png" alt="Leadstars" class="cs-proof-item__logo" />
            </div>
            <div class="cs-proof-item__info">
              <span class="cs-proof-item__result">€20K+/mnd</span>
              <span class="cs-proof-item__label">Structurele dealflow</span>
            </div>
          </div>
          <div class="cs-proof-divider"></div>
          <div class="cs-proof-item">
            <div class="cs-proof-item__logo-wrap cs-proof-item__logo-wrap--dark">
              <img src="/images/clients/van-de-bilt-energy.png" alt="Van de Bilt Energy" class="cs-proof-item__logo" />
            </div>
            <div class="cs-proof-item__info">
              <span class="cs-proof-item__result">2 deals</span>
              <span class="cs-proof-item__label">Gesloten in week 1</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       STATS BAR
  ================================================ -->
  <section class="cs-statsbar">
    <div class="container cs-statsbar__inner">
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">50+</span>
        <span class="cs-statsbar__label">Succesvolle matches</span>
      </div>
      <div class="cs-statsbar__divider"></div>
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">€50K+</span>
        <span class="cs-statsbar__label">Deals gesloten via ons platform</span>
      </div>
      <div class="cs-statsbar__divider"></div>
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">Week 1</span>
        <span class="cs-statsbar__label">Gemiddeld eerste resultaten</span>
      </div>
      <div class="cs-statsbar__divider"></div>
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">No cure</span>
        <span class="cs-statsbar__label">No pay — betaal alleen bij resultaat</span>
      </div>
    </div>
  </section>

  <!-- ================================================
       CASES
  ================================================ -->
  <section class="section cs-cases" id="cases">
    <div class="container">
      <div class="cs-cases__header">
        <span class="label">Bewezen resultaten</span>
        <h2 class="h2 cs-cases__title">Drie branches.<br />Drie matches. Allemaal resultaat<br /><span class="cs-cases__title-red">vanaf week één.</span></h2>
        <p class="cs-cases__sub">Elk bedrijf had een ander probleem. Elk bedrijf kreeg een op maat gemaakte ClosersMatch-oplossing. En elk bedrijf zag resultaat — snel, meetbaar en herhaalbaar.</p>
      </div>

      <div class="cs-cases__grid">

        <!-- DetachPro -->
        <div class="cs-case-card">
          <div class="cs-case-card__header">
            <div class="cs-case-card__logo-wrap cs-case-card__logo-wrap--light">
              <img src="/images/clients/detachpro.png" alt="DetachPro" class="cs-case-card__logo" />
            </div>
            <div class="cs-case-card__meta">
              <span class="cs-case-card__branche">Technische detachering</span>
              <span class="cs-case-card__badge cs-case-card__badge--green">Resultaat behaald</span>
            </div>
          </div>

          <div class="cs-case-card__body">
            <p class="cs-case-card__desc">DetachPro verbindt technische professionals met bedrijven die tijdelijk of structureel capaciteit nodig hebben. Een sterk aanbod — maar warme leads werden niet consequent geclost.</p>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                De uitdaging
              </div>
              <p class="cs-case-section__text">Warme leads lagen onbenut. Er was geen dedicated closer beschikbaar en de interne opvolging was inconsistent. Potenti├½le deals liepen weg zonder dat er ooit echt een gesprek plaatsvond.</p>
            </div>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/></svg>
                De ClosersMatch aanpak
              </div>
              <p class="cs-case-section__text">ClosersMatch koppelde DetachPro aan een CM Certified closer met aantoonbare ervaring in B2B-dienstverlening. Geen inwerkperiode. Geen langdurige onboarding. Direct commercieel inzetbaar.</p>
            </div>

            <div class="cs-case-result">
              <div class="cs-case-result__num">€50.000</div>
              <div class="cs-case-result__label">Deal gesloten in week één</div>
            </div>

            <blockquote class="cs-case-quote">
              "Geen inwerkperiode. Direct commercieel resultaat."
            </blockquote>
          </div>
        </div>

        <!-- Van de Bilt Energy -->
        <div class="cs-case-card cs-case-card--featured">
          <div class="cs-case-card__header">
            <div class="cs-case-card__logo-wrap cs-case-card__logo-wrap--dark">
              <img src="/images/clients/van-de-bilt-energy.png" alt="Van de Bilt Energy" class="cs-case-card__logo" />
            </div>
            <div class="cs-case-card__meta">
              <span class="cs-case-card__branche">Duurzame energie</span>
              <span class="cs-case-card__badge cs-case-card__badge--red">Uitgelicht</span>
            </div>
          </div>

          <div class="cs-case-card__body">
            <p class="cs-case-card__desc">Van de Bilt Energy levert thuisbatterijsystemen en duurzame energieoplossingen aan particulieren en bedrijven. Kwalitatief product — maar de salescyclus was lang en de conversie teleurstellend.</p>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                De uitdaging
              </div>
              <p class="cs-case-section__text">Lange salescyclus met lage conversie. Leads kwamen binnen, maar het ontbrak aan de juiste opvolging en afsluiting. De combinatie van een setter én closer ontbrak volledig in het proces.</p>
            </div>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/></svg>
                De ClosersMatch aanpak
              </div>
              <p class="cs-case-section__text">ClosersMatch implementeerde een tandem-model: een appointment setter voor kwalificatie en warm houden van leads, gekoppeld aan een CM Certified closer voor de definitieve afsluiting. Het volledige salesproces — van eerste contact tot handtekening — werd afgedekt.</p>
            </div>

            <div class="cs-case-result">
              <div class="cs-case-result__num">2 systemen</div>
              <div class="cs-case-result__label">Verkocht in week één</div>
            </div>

            <blockquote class="cs-case-quote">
              "Van lead naar gesloten deal. Snelle conversie, bewezen propositie."
            </blockquote>
          </div>
        </div>

        <!-- Leadstars -->
        <div class="cs-case-card">
          <div class="cs-case-card__header">
            <div class="cs-case-card__logo-wrap cs-case-card__logo-wrap--dark">
              <img src="/images/clients/leadstars.png" alt="Leadstars" class="cs-case-card__logo" />
            </div>
            <div class="cs-case-card__meta">
              <span class="cs-case-card__branche">Leadgeneratie &amp; groei</span>
              <span class="cs-case-card__badge cs-case-card__badge--green">Resultaat behaald</span>
            </div>
          </div>

          <div class="cs-case-card__body">
            <p class="cs-case-card__desc">Leadstars helpt bedrijven structureel groeien via verbeterde zichtbaarheid, leadgeneratie en dealcreatie. Sterke propositie — maar inconsistente deal flow zorgde voor grillige maandcijfers.</p>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                De uitdaging
              </div>
              <p class="cs-case-section__text">De deal flow was inconsistent en afhankelijk van externe factoren. Er was geen gestructureerd salesproces met voorspelbare output, waardoor groei stagneerde en planning onmogelijk was.</p>
            </div>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/></svg>
                De ClosersMatch aanpak
              </div>
              <p class="cs-case-section__text">ClosersMatch plaatste een dedicated CM Certified closer op no cure no pay basis. Volledige focus op het sluiten van nieuwe deals, met CRM-integratie voor volledige transparantie en rapportage. Schaalbaar model, nul vast risico.</p>
            </div>

            <div class="cs-case-result">
              <div class="cs-case-result__num">€20.000+</div>
              <div class="cs-case-result__label">Per maand aan nieuwe deals</div>
            </div>

            <blockquote class="cs-case-quote">
              "Consistente deal flow. Schaalbaar en meetbaar."
            </blockquote>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT VOOR BEDRIJVEN
  ================================================ -->
  <section class="section cs-hiw">
    <div class="container">
      <div class="cs-hiw__inner">
        <div class="cs-hiw__content">
          <span class="label">Hoe het werkt</span>
          <h2 class="h2 cs-hiw__title">Van eerste gesprek<br />tot gesloten deal.<br /><span class="cs-hiw__title-red">In drie stappen.</span></h2>
          <p class="cs-hiw__body">Ons matchingsproces is ontworpen om zo snel mogelijk resultaat te leveren. Geen langdurige trajecten, geen stapels papierwerk, geen weken van wachten. Van intake tot eerste deal — gemiddeld in één week.</p>
          <a href="/nl/contact" class="btn btn--red btn--lg cs-hiw__cta">Plan je gratis intake →</a>
        </div>

        <div class="cs-hiw__steps">
          <div class="cs-hiw__step">
            <div class="cs-hiw__step-left">
              <div class="cs-hiw__step-num">01</div>
              <div class="cs-hiw__step-line"></div>
            </div>
            <div class="cs-hiw__step-content">
              <h3 class="cs-hiw__step-title">Intake</h3>
              <p class="cs-hiw__step-text">Wij leren jouw bedrijf, product en doelgroep kennen. In een gratis gesprek van 30 minuten bepalen we welk profiel — closer, setter of combinatie — het beste aansluit bij jouw salesproces en dealgrootte. Geen kosten. Geen verplichtingen.</p>
            </div>
          </div>

          <div class="cs-hiw__step">
            <div class="cs-hiw__step-left">
              <div class="cs-hiw__step-num">02</div>
              <div class="cs-hiw__step-line"></div>
            </div>
            <div class="cs-hiw__step-content">
              <h3 class="cs-hiw__step-title">Match</h3>
              <p class="cs-hiw__step-text">Binnen 48 uur koppelen we je aan de juiste CM Certified professional. Geen cv's, geen sollicitatiegesprekken, geen gokwerk. Wij matchen op branchekennis, salesstijl en aantoonbaar track record.</p>
            </div>
          </div>

          <div class="cs-hiw__step cs-hiw__step--last">
            <div class="cs-hiw__step-left">
              <div class="cs-hiw__step-num">03</div>
            </div>
            <div class="cs-hiw__step-content">
              <h3 class="cs-hiw__step-title">Resultaat</h3>
              <p class="cs-hiw__step-text">De closer gaat direct aan de slag. Scripts worden opgesteld, CRM ingericht en het salesproces geactiveerd — gratis. Jij ziet alles in real-time via het dashboard. En betaalt alleen als er deals worden gesloten.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       SOCIAL PROOF STRIP
  ================================================ -->
  <section class="cs-proof-strip">
    <div class="container cs-proof-strip__inner">
      <div class="cs-proof-strip__item">
        <span class="cs-proof-strip__quote">"Geen inwerkperiode. Direct commercieel resultaat."</span>
        <span class="cs-proof-strip__source">— DetachPro</span>
      </div>
      <div class="cs-proof-strip__divider"></div>
      <div class="cs-proof-strip__item">
        <span class="cs-proof-strip__quote">"Van lead naar gesloten deal. Snelle conversie."</span>
        <span class="cs-proof-strip__source">— Van de Bilt Energy</span>
      </div>
      <div class="cs-proof-strip__divider"></div>
      <div class="cs-proof-strip__item">
        <span class="cs-proof-strip__quote">"Consistente deal flow. Schaalbaar en meetbaar."</span>
        <span class="cs-proof-strip__source">— Leadstars</span>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="cs-closing">
    <div class="cs-closing__inner">
      <span class="label label--ghost-light">No cure no pay</span>
      <h2 class="cs-closing__title">
        Wil jij het volgende<br />succesverhaal zijn?
      </h2>
      <p class="cs-closing__body">
        DetachPro, Van de Bilt Energy en Leadstars gingen je voor. Tientallen andere bedrijven ook. Het enige wat hen verbindt: ze namen actie en planden een gratis intake.<br /><br />
        Jouw commerci├½le doorbraak begint met één gesprek.
      </p>
      <a href="/nl/contact" class="btn btn--red btn--xl cs-closing__btn">Plan je gratis intake →</a>
      <p class="cs-closing__sub">Geen verplichtingen. Geen kosten vooraf. Wél een helder beeld van wat mogelijk is voor jouw bedrijf.</p>
      <p class="cs-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .cs-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .cs-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .cs-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .cs-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .cs-hero__title-red { color: var(--color-red); }

  .cs-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .cs-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .cs-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Proof card rechts */
  .cs-hero__proof-card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-proof-header {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 20px;
  }

  .cs-proof-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
  }

  .cs-proof-item__logo-wrap {
    height: 44px;
    min-width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: var(--radius);
    flex-shrink: 0;
  }

  .cs-proof-item__logo-wrap--light { background: #f3f4f6; }
  .cs-proof-item__logo-wrap--dark { background: #1a1a1a; }

  .cs-proof-item__logo {
    height: 26px;
    width: auto;
    object-fit: contain;
    max-width: 100px;
  }

  .cs-proof-item__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-proof-item__result {
    font-size: 1.1rem;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .cs-proof-item__label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.3;
  }

  .cs-proof-divider {
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  @media (max-width: 960px) {
    .cs-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .cs-hero { padding: 100px 0 60px; }
    .cs-hero__actions { flex-direction: column; align-items: stretch; }
    .cs-hero__actions .btn { width: 100%; justify-content: center; }
  }

  /* ====================================================
     STATS BAR
  ==================================================== */
  .cs-statsbar {
    background: var(--color-black);
    padding: 40px 0;
  }

  .cs-statsbar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .cs-statsbar__stat {
    text-align: center;
  }

  .cs-statsbar__num {
    display: block;
    font-size: 1.8rem;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .cs-statsbar__label {
    display: block;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  .cs-statsbar__divider {
    width: 1px;
    height: 44px;
    background: rgba(255,255,255,0.1);
  }

  @media (max-width: 700px) {
    .cs-statsbar__divider { display: none; }
    .cs-statsbar__inner { gap: 28px; }
  }

  /* ====================================================
     CASES
  ==================================================== */
  .cs-cases { background: #F9FAFB; }

  .cs-cases__header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
  }

  .cs-cases__title {
    margin-top: 16px;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .cs-cases__title-red { color: var(--color-red); }

  .cs-cases__sub {
    font-size: 1rem;
    color: var(--color-gray-mid);
    line-height: 1.7;
  }

  .cs-cases__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    align-items: start;
  }

  .cs-case-card {
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .cs-case-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .cs-case-card--featured {
    border-color: var(--color-red);
    box-shadow: 0 0 0 1px var(--color-red);
  }

  .cs-case-card__header {
    padding: 28px 28px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--color-gray-border);
  }

  .cs-case-card--featured .cs-case-card__header {
    border-bottom-color: rgba(221,52,46,0.15);
  }

  .cs-case-card__logo-wrap {
    height: 48px;
    display: flex;
    align-items: center;
    padding: 6px 14px;
