---
import Layout from '../../layouts/Layout.astro';
---

<Layout locale="nl" title="Voor appointment setters — ClosersMatch" description="Word onderdeel van het ClosersMatch setter netwerk. Gescreende bedrijven, CM training, AI-coaching en opdrachten die bij jou passen. Jij boekt de afspraken. Wij regelen de rest.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="vas-hero">
    <div class="container vas-hero__inner">
      <div class="vas-hero__content">
        <span class="label label--red">Voor appointment setters</span>
        <h1 class="vas-hero__title">
          Gesprekken openen.<br />
          Kansen creëren.<br />
          <span class="vas-hero__title-red">Betaald per afspraak.</span>
        </h1>
        <p class="vas-hero__subtitle">
          ClosersMatch koppelt appointment setters aan gescreende B2B-bedrijven met bewezen aanbod. Geen eindeloos prospecteren. Geen solliciteren. Jij richt je op gesprekken — wij regelen de rest.
        </p>
        <div class="vas-hero__trust-pills">
          <span class="trust-pill">✓ Betaald per afspraak</span>
          <span class="trust-pill">✓ Gescreende bedrijven</span>
          <span class="trust-pill">✓ CM Setter training</span>
        </div>
        <div class="vas-hero__actions">
          <button type="button" class="btn btn--red btn--lg" data-meeting-modal-person="talent">Word lid van het netwerk →</button>
          <a href="#hoe-het-werkt" class="btn btn--outline-dark-mode">Hoe het werkt</a>
        </div>
        <p class="vas-hero__note">Alleen goedgekeurde leden krijgen toegang.</p>
      </div>

      <div class="vas-hero__visual">
        <div class="vas-hero__card">
          <div class="vas-hero__card-header">
            <span class="vas-hero__card-label">Jouw focus als setter</span>
          </div>
          <div class="vas-hero__card-items">
            <div class="vas-card-item vas-card-item--active">
              <div class="vas-card-item__icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Leads kwalificeren</strong>
                <span>Alleen serieuze kopers komen door</span>
              </div>
            </div>
            <div class="vas-card-item vas-card-item--active">
              <div class="vas-card-item__icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Gesprekken openen</strong>
                <span>LinkedIn, e-mail en telefoon</span>
              </div>
            </div>
            <div class="vas-card-item vas-card-item--active">
              <div class="vas-card-item__icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Afspraken inplannen</strong>
                <span>Warm en klaar voor de closer</span>
              </div>
            </div>
            <div class="vas-card-item">
              <div class="vas-card-item__icon vas-card-item__icon--gray">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
              <div>
                <strong>Doorgroeien naar closer</strong>
                <span>Wanneer jij er klaar voor bent</span>
              </div>
            </div>
          </div>
          <div class="vas-hero__card-footer">
            <span class="vas-hero__card-stat"><strong>50+</strong> matches</span>
            <span class="vas-hero__card-dot">•</span>
            <span class="vas-hero__card-stat">Betaald <strong>per afspraak</strong></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAAROM CLOSERSMATCH
  ================================================ -->
  <section class="section vas-waarom">
    <div class="container">
      <div class="vas-waarom__inner">
        <div class="vas-waarom__content">
          <span class="label">Waarom ClosersMatch</span>
          <h2 class="h2 vas-waarom__title">De meeste setters zoeken<br />naar werk. Onze leden<br /><span class="vas-waarom__title-red">doen het.</span></h2>
          <p class="vas-waarom__body">Eindeloos prospecteren, solliciteren op platforms en toch maar afwachten of er wat binnenkomt. Dat is hoe de meeste appointment setters hun tijd verspillen.</p>
          <p class="vas-waarom__body">Bij ClosersMatch krijg je direct toegang tot gescreende bedrijven die klaar zijn om mee te werken. Jij richt je op gesprekken voeren — alles eromheen is al geregeld.</p>
          <button type="button" class="btn btn--red" data-meeting-modal-person="talent">Meld je aan →</button>
        </div>

        <div class="vas-waarom__checklist">
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Toegang tot gescreende B2B-bedrijven</h3>
              <p class="vas-waarom__check-text">Elk bedrijf in ons netwerk is beoordeeld. Serieuze bedrijven, bewezen aanbod, duidelijke processen. Geen tijdverspilling.</p>
            </div>
          </div>
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Werk met bewezen producten</h3>
              <p class="vas-waarom__check-text">Je belt namens bedrijven met een product of dienst die werkt. Geen onzekerheid over wat je verkoopt of aan wie.</p>
            </div>
          </div>
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Doorlopende begeleiding</h3>
              <p class="vas-waarom__check-text">AI-coaching na elk gesprek, wekelijkse feedback en een community van salesprofessionals. Je stopt nooit met beter worden.</p>
            </div>
          </div>
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Focus op prestaties, niet op werven</h3>
              <p class="vas-waarom__check-text">Geen tijd kwijt aan zoeken naar opdrachten. Wij brengen de kansen naar jou. Jij scoort de afspraken.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT
  ================================================ -->
  <section class="section vas-hiw" id="hoe-het-werkt">
    <div class="container">
      <div class="vas-hiw__header">
        <span class="label">Het proces</span>
        <h2 class="h2 vas-hiw__title">Van aanmelding tot<br />jouw eerste afspraak.</h2>
      </div>

      <div class="vas-hiw__grid">
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">01</div>
          <h3 class="vas-hiw__step-title">Aanmelden &amp; screening</h3>
          <p class="vas-hiw__step-text">Je meldt je aan via het formulier. Wij beoordelen je motivatie, communicatiestijl en potentieel. Alleen geschikte kandidaten gaan door — zo blijft de kwaliteit van het netwerk hoog.</p>
        </div>
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">02</div>
          <h3 class="vas-hiw__step-title">CM Setter training</h3>
          <p class="vas-hiw__step-text">Je leert hoe je leads kwalificeert, gesprekken opent via LinkedIn, e-mail en telefoon, en prospects warm houdt. Praktijkgericht, met AI-feedback en echte scripts voor echte situaties.</p>
        </div>
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">03</div>
          <h3 class="vas-hiw__step-title">Matching met een bedrijf</h3>
          <p class="vas-hiw__step-text">We koppelen je aan een bedrijf dat past bij jouw stijl, branche en beschikbaarheid. Je krijgt inzicht in het product, de doelgroep en de aanpak — vóór je eerste gesprek.</p>
        </div>
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">04</div>
          <h3 class="vas-hiw__step-title">Afspraken boeken &amp; groeien</h3>
          <p class="vas-hiw__step-text">Je gaat aan de slag. Elk gesprek wordt geanalyseerd, feedback gegeven. Betaald per gekwalificeerde afspraak. Klaar voor de volgende stap? De weg naar closer staat open.</p>
        </div>
      </div>

      <div class="vas-hiw__cta">
        <button type="button" class="btn btn--red btn--lg" data-meeting-modal-person="talent">Start als appointment setter →</button>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAT JE LEERT
  ================================================ -->
  <section class="section vas-training">
    <div class="container">
      <div class="vas-training__inner">
        <div class="vas-training__content">
          <span class="label label--red">CM Setter training</span>
          <h2 class="h2 vas-training__title">Ontworpen voor de moderne appointment setter.</h2>
          <p class="vas-training__body">De wereld van sales verandert snel. LinkedIn, e-mail, AI — de setter die weet hoe hij al deze kanalen inzet, wint. Onze training geeft je exact dat.</p>
          <p class="vas-training__body">Geen theorie. Praktijkgerichte opleiding op basis van echte gesprekken, met directe feedback en AI-analyse na elk contact.</p>

          <div class="vas-training__skills">
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              LinkedIn outreach &amp; connectiestrategieën
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Cold e-mail frameworks die converteren
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Lead kwalificatie &amp; vraagstelling
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Communicatiecoaching &amp; toonzetting
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              AI-feedback &amp; prestatie-inzichten
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Gepersonaliseerde scripts per prospect
            </div>
          </div>
        </div>

        <div class="vas-training__card">
          <div class="vas-training__card-header">
            <span class="vas-training__card-badge">CM Certified Setter</span>
            <h3 class="vas-training__card-title">Wat je na de training kunt</h3>
          </div>
          <div class="vas-training__outcomes">
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">01</span>
              <p>Leads kwalificeren op koopintentie — zo sla je nooit meer tijd aan de verkeerde prospects</p>
            </div>
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">02</span>
              <p>Een gesprek openen op elk kanaal — LinkedIn, e-mail of telefoon — op een manier die reactie uitlokt</p>
            </div>
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">03</span>
              <p>Bezwaren pareren en prospects warm houden totdat de closer de deal sluit</p>
            </div>
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">04</span>
              <p>Je eigen resultaten meten en wekelijks verbeteren op basis van data en coaching</p>
            </div>
          </div>
          <button type="button" class="btn btn--red vas-training__card-cta" data-meeting-modal-person="talent">Start jouw training →</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAT JE KRIJGT (ecosystem)
  ================================================ -->
  <section class="section vas-eco">
    <div class="container">
      <div class="vas-eco__header">
        <span class="label">Meer dan een opdracht</span>
        <h2 class="h2 vas-eco__title">Een compleet systeem<br />om te groeien als setter.</h2>
        <p class="vas-eco__sub">De meeste platforms helpen je bij het vinden van werk. ClosersMatch helpt je bij het opbouwen van een carrière.</p>
      </div>

      <div class="vas-eco__grid">
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3l-4 4-4-4"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Gekwalificeerde opdrachten</h3>
          <p class="vas-eco-card__text">Directe toegang tot bedrijven die actief zoeken naar appointment setters. Geen eindeloos solliciteren of prospecteren.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="vas-eco-card__title">CM Setter training</h3>
          <p class="vas-eco-card__text">Praktijkgerichte training op basis van echte gesprekken. LinkedIn, cold e-mail, telefonisch kwalificeren — alles komt aan bod.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
          </div>
          <h3 class="vas-eco-card__title">AI-coaching &amp; feedback</h3>
          <p class="vas-eco-card__text">Elk gesprek wordt geanalyseerd. Je krijgt inzicht in je conversieratio, reactietijd en communicatiestijl — automatisch.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Setter community</h3>
          <p class="vas-eco-card__text">Een actieve community van gecertificeerde setters en closers. Scripts delen, ervaringen uitwisselen, scherp blijven.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Prestatie dashboard</h3>
          <p class="vas-eco-card__text">Real-time inzicht in je afspraken, conversies en inkomsten. Jij bepaalt je eigen tempo en groei.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Groeipad naar closer</h3>
          <p class="vas-eco-card__text">Wanneer je er klaar voor bent, is de stap naar closer een logische volgende stap. Niet verplicht. Wel mogelijk — en begeleiding staat klaar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AI PERFORMANCE PLATFORM
  ================================================ -->
  <section class="section vas-ai">
    <div class="container">
      <div class="vas-ai__inner">
        <div class="vas-ai__content">
          <span class="label label--red">AI Performance Platform</span>
          <h2 class="h2 vas-ai__title">Live feedback op elk gesprek.<br />Ook je eigen.</h2>
          <p class="vas-ai__body">Naast de CM Setter training krijg je toegang tot het AI Performance Platform. Oefen met AI op basis van verschillende branches en bezwaren, met live feedback tijdens het gesprek. Bel je daarna een echte lead? Bij calls werkt het systeem exact hetzelfde: live feedback tijdens het gesprek en een analyse achteraf.</p>
          <ul class="vas-ai__list">
            <li>✓ Inzicht in opening, vraagtechniek, luistervaardigheid &amp; bezwaren</li>
            <li>✓ Persoonlijk scorebord met afspraakkwaliteit en conversie</li>
            <li>✓ Directe AI-feedback, bovenop coaching van Stefan Kelderman</li>
            <li>✓ Verified profiel, zichtbaar voor bedrijven binnen het netwerk</li>
          </ul>
          <a href="/nl/academy" class="btn btn--red vas-ai__cta">Ontdek de Academy &amp; AI-platform →</a>
        </div>
        <div class="vas-ai__visual">
          <div class="vas-ai__card">
            <div class="vas-ai__card-row"><span>Live feedback tijdens gesprek</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>Analyse achteraf</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>Persoonlijk scorebord</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>1-op-1 coaching Stefan Kelderman</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>Verified profiel</span><strong>✓</strong></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="vas-closing">
    <div class="vas-closing__inner">
      <span class="label label--ghost-light">Beperkt aantal plaatsen</span>
      <h2 class="vas-closing__title">
        Stop met zoeken<br />naar opdrachten.<br />
        <span class="vas-closing__title-red">Begin met scoren.</span>
      </h2>
      <p class="vas-closing__body">
        ClosersMatch geeft appointment setters toegang tot de bedrijven, de training en het systeem om écht te presteren. Geen platforms. Geen cold starts. Gewoon aan de slag.
      </p>
      <button type="button" class="btn btn--red btn--xl vas-closing__btn" data-meeting-modal-person="talent">Meld je aan als setter →</button>
      <p class="vas-closing__sub">Gratis aanmelding. Alleen gemotiveerde appointment setters welkom.</p>
      <p class="vas-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .vas-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .vas-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .vas-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .vas-hero__title {
    font-size: clamp(1.9rem, 3.6vw, 3rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .vas-hero__title-red { color: var(--color-red); }

  .vas-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .vas-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
  }

  .vas-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 16px;
  }

  .vas-hero__note {
    font-size: 0.82rem;
    color: var(--color-gray-mid);
    font-style: italic;
  }

  /* Card rechts */
  .vas-hero__card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .vas-hero__card-header {
    padding: 18px 24px;
    background: rgba(221,52,46,0.15);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .vas-hero__card-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .vas-hero__card-items {
    padding: 8px 0;
  }

  .vas-card-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 12px;
    align-items: center;
