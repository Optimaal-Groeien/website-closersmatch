<Layout locale="en" title="General Terms and Conditions — ClosersMatch" description="Read the general terms and conditions of ClosersMatch, part of Optimaal Groeien. Terms for clients and closers/appointment setters using the platform.">

  <!-- ================================================
       HERO
  ================================================ -->
