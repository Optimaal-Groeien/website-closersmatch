---
import Layout from '../layouts/Layout.astro';
---

<Layout locale="en" title="Client Cases & Results — ClosersMatch" description="No forecasts. Real results from real companies. See how DetachPro, Van de Bilt Energy, and Leadstars achieved commercial success through ClosersMatch.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="cs-hero">
    <div class="container cs-hero__inner">
      <div class="cs-hero__content">
        <span class="label label--red">Client cases &amp; results</span>
        <h1 class="cs-hero__title">
          Results that speak for themselves.<br />
          <span class="cs-hero__title-red">Not forecasts.</span>
        </h1>
        <p class="cs-hero__subtitle">
          We let the numbers do the talking. No vague stories about what might be possible, but proven results from real companies that broke through commercially with ClosersMatch. Deals closed. Revenue generated. From week one.
        </p>
        <div class="cs-hero__trust-pills">
          <span class="trust-pill">✓ Proven track record</span>
          <span class="trust-pill">✓ Results from week 1</span>
          <span class="trust-pill">✓ No cure no pay</span>
        </div>
        <div class="cs-hero__actions">
          <a href="/contact" class="btn btn--red btn--lg">Book your free intake →</a>
          <a href="#cases" class="btn btn--outline-dark-mode">View the cases</a>
        </div>
      </div>

      <div class="cs-hero__visual">
        <div class="cs-hero__proof-card">
          <div class="cs-proof-header">Closed deals via ClosersMatch</div>
          <div class="cs-proof-item">
            <div class="cs-proof-item__logo-wrap cs-proof-item__logo-wrap--light">
              <img src="/images/clients/detachpro.png" alt="DetachPro" class="cs-proof-item__logo" />
            </div>
            <div class="cs-proof-item__info">
              <span class="cs-proof-item__result">€50.000</span>
              <span class="cs-proof-item__label">Deal closed, week 1</span>
            </div>
          </div>
          <div class="cs-proof-divider"></div>
          <div class="cs-proof-item">
            <div class="cs-proof-item__logo-wrap cs-proof-item__logo-wrap--dark">
              <img src="/images/clients/leadstars.png" alt="Leadstars" class="cs-proof-item__logo" />
            </div>
            <div class="cs-proof-item__info">
              <span class="cs-proof-item__result">€20K+/mnd</span>
              <span class="cs-proof-item__label">Consistent deal flow</span>
            </div>
          </div>
          <div class="cs-proof-divider"></div>
          <div class="cs-proof-item">
            <div class="cs-proof-item__logo-wrap cs-proof-item__logo-wrap--dark">
              <img src="/images/clients/van-de-bilt-energy.png" alt="Van de Bilt Energy" class="cs-proof-item__logo" />
            </div>
            <div class="cs-proof-item__info">
              <span class="cs-proof-item__result">2 deals</span>
              <span class="cs-proof-item__label">Closed in week 1</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       STATS BAR
  ================================================ -->
  <section class="cs-statsbar">
    <div class="container cs-statsbar__inner">
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">50+</span>
        <span class="cs-statsbar__label">Successful matches</span>
      </div>
      <div class="cs-statsbar__divider"></div>
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">€50K+</span>
        <span class="cs-statsbar__label">Deals closed via our platform</span>
      </div>
      <div class="cs-statsbar__divider"></div>
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">Week 1</span>
        <span class="cs-statsbar__label">Average time to first results</span>
      </div>
      <div class="cs-statsbar__divider"></div>
      <div class="cs-statsbar__stat">
        <span class="cs-statsbar__num">No cure</span>
        <span class="cs-statsbar__label">No pay, you only pay for results</span>
      </div>
    </div>
  </section>

  <!-- ================================================
       CASES
  ================================================ -->
  <section class="section cs-cases" id="cases">
    <div class="container">
      <div class="cs-cases__header">
        <span class="label">Proven results</span>
        <h2 class="h2 cs-cases__title">Three industries.<br />Three matches. All with results<br /><span class="cs-cases__title-red">from week one.</span></h2>
        <p class="cs-cases__sub">Every company had a different problem. Every company received a tailored ClosersMatch solution. And every company saw results, fast, measurable, and repeatable.</p>
      </div>

      <div class="cs-cases__grid">

        <!-- DetachPro -->
        <div class="cs-case-card">
          <div class="cs-case-card__header">
            <div class="cs-case-card__logo-wrap cs-case-card__logo-wrap--light">
              <img src="/images/clients/detachpro.png" alt="DetachPro" class="cs-case-card__logo" />
            </div>
            <div class="cs-case-card__meta">
              <span class="cs-case-card__branche">Technical staffing</span>
              <span class="cs-case-card__badge cs-case-card__badge--green">Results delivered</span>
            </div>
          </div>

          <div class="cs-case-card__body">
            <p class="cs-case-card__desc">DetachPro connects technical professionals with companies that need temporary or structural capacity. A strong offering, but warm leads were not being closed consistently.</p>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                The challenge
              </div>
              <p class="cs-case-section__text">Warm leads were going unused. There was no dedicated closer available and internal follow-up was inconsistent. Potential deals slipped away without a real conversation ever taking place.</p>
            </div>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/></svg>
                The ClosersMatch approach
              </div>
              <p class="cs-case-section__text">ClosersMatch paired DetachPro with a CM Certified closer with proven experience in B2B services. No ramp-up period. No lengthy onboarding. Commercially ready from day one.</p>
            </div>

            <div class="cs-case-result">
              <div class="cs-case-result__num">€50.000</div>
              <div class="cs-case-result__label">Deal closed in week one</div>
            </div>

            <blockquote class="cs-case-quote">
              "No ramp-up period. Immediate commercial results."
            </blockquote>
          </div>
        </div>

        <!-- Van de Bilt Energy -->
        <div class="cs-case-card cs-case-card--featured">
          <div class="cs-case-card__header">
            <div class="cs-case-card__logo-wrap cs-case-card__logo-wrap--dark">
              <img src="/images/clients/van-de-bilt-energy.png" alt="Van de Bilt Energy" class="cs-case-card__logo" />
            </div>
            <div class="cs-case-card__meta">
              <span class="cs-case-card__branche">Sustainable energy</span>
              <span class="cs-case-card__badge cs-case-card__badge--red">Featured</span>
            </div>
          </div>

          <div class="cs-case-card__body">
            <p class="cs-case-card__desc">Van de Bilt Energy delivers home battery systems and sustainable energy solutions to consumers and businesses. A quality product, but the sales cycle was long and conversion disappointing.</p>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                The challenge
              </div>
              <p class="cs-case-section__text">Long sales cycle with low conversion. Leads came in, but the right follow-up and closing were missing. The combination of a setter and closer was entirely absent from the process.</p>
            </div>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/></svg>
                The ClosersMatch approach
              </div>
              <p class="cs-case-section__text">ClosersMatch implemented a tandem model: an appointment setter for qualification and lead nurturing, paired with a CM Certified closer for the final close. The full sales process, from first contact to signed contract, was covered.</p>
            </div>

            <div class="cs-case-result">
              <div class="cs-case-result__num">2 systems</div>
              <div class="cs-case-result__label">Sold in week one</div>
            </div>

            <blockquote class="cs-case-quote">
              "From lead to closed deal. Fast conversion, proven proposition."
            </blockquote>
          </div>
        </div>

        <!-- Leadstars -->
        <div class="cs-case-card">
          <div class="cs-case-card__header">
            <div class="cs-case-card__logo-wrap cs-case-card__logo-wrap--dark">
              <img src="/images/clients/leadstars.png" alt="Leadstars" class="cs-case-card__logo" />
            </div>
            <div class="cs-case-card__meta">
              <span class="cs-case-card__branche">Lead generation &amp; growth</span>
              <span class="cs-case-card__badge cs-case-card__badge--green">Results delivered</span>
            </div>
          </div>

          <div class="cs-case-card__body">
            <p class="cs-case-card__desc">Leadstars helps companies grow structurally through improved visibility, lead generation, and deal creation. A strong proposition, but inconsistent deal flow led to volatile monthly numbers.</p>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                The challenge
              </div>
              <p class="cs-case-section__text">Deal flow was inconsistent and dependent on external factors. There was no structured sales process with predictable output, so growth stalled and planning became impossible.</p>
            </div>

            <div class="cs-case-section">
              <div class="cs-case-section__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/></svg>
                The ClosersMatch approach
              </div>
              <p class="cs-case-section__text">ClosersMatch placed a dedicated CM Certified closer on a no cure no pay basis. Full focus on closing new deals, with CRM integration for complete transparency and reporting. A scalable model with zero fixed risk.</p>
            </div>

            <div class="cs-case-result">
              <div class="cs-case-result__num">€20.000+</div>
              <div class="cs-case-result__label">In new deals per month</div>
            </div>

            <blockquote class="cs-case-quote">
              "Consistent deal flow. Scalable and measurable."
            </blockquote>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT VOOR BEDRIJVEN
  ================================================ -->
  <section class="section cs-hiw">
    <div class="container">
      <div class="cs-hiw__inner">
        <div class="cs-hiw__content">
          <span class="label">How it works</span>
          <h2 class="h2 cs-hiw__title">From first conversation<br />to closed deal.<br /><span class="cs-hiw__title-red">In three steps.</span></h2>
          <p class="cs-hiw__body">Our matching process is designed to deliver results as quickly as possible. No long trajectories, no stacks of paperwork, no weeks of waiting. From intake to first deal, on average in one week.</p>
          <a href="/contact" class="btn btn--red btn--lg cs-hiw__cta">Book your free intake →</a>
        </div>

        <div class="cs-hiw__steps">
          <div class="cs-hiw__step">
            <div class="cs-hiw__step-left">
              <div class="cs-hiw__step-num">01</div>
              <div class="cs-hiw__step-line"></div>
            </div>
            <div class="cs-hiw__step-content">
              <h3 class="cs-hiw__step-title">Intake</h3>
              <p class="cs-hiw__step-text">We get to know your company, product, and target audience. In a free 30-minute call, we determine which profile, closer, setter, or combination, best fits your sales process and deal size. No cost. No obligations.</p>
            </div>
          </div>

          <div class="cs-hiw__step">
            <div class="cs-hiw__step-left">
              <div class="cs-hiw__step-num">02</div>
              <div class="cs-hiw__step-line"></div>
            </div>
            <div class="cs-hiw__step-content">
              <h3 class="cs-hiw__step-title">Match</h3>
              <p class="cs-hiw__step-text">Within 48 hours, we connect you with the right CM Certified professional. No CVs, no job interviews, no guesswork. We match on industry knowledge, sales style, and proven track record.</p>
            </div>
          </div>

          <div class="cs-hiw__step cs-hiw__step--last">
            <div class="cs-hiw__step-left">
              <div class="cs-hiw__step-num">03</div>
            </div>
            <div class="cs-hiw__step-content">
              <h3 class="cs-hiw__step-title">Results</h3>
              <p class="cs-hiw__step-text">The closer gets to work immediately. Scripts are prepared, CRM is set up, and the sales process is activated, at no cost. You see everything in real time via the dashboard. And you only pay when deals are closed.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       SOCIAL PROOF STRIP
  ================================================ -->
  <section class="cs-proof-strip">
    <div class="container cs-proof-strip__inner">
      <div class="cs-proof-strip__item">
        <span class="cs-proof-strip__quote">"No ramp-up period. Immediate commercial results."</span>
        <span class="cs-proof-strip__source">— DetachPro</span>
      </div>
      <div class="cs-proof-strip__divider"></div>
      <div class="cs-proof-strip__item">
        <span class="cs-proof-strip__quote">"From lead to closed deal. Fast conversion."</span>
        <span class="cs-proof-strip__source">— Van de Bilt Energy</span>
      </div>
      <div class="cs-proof-strip__divider"></div>
      <div class="cs-proof-strip__item">
        <span class="cs-proof-strip__quote">"Consistent deal flow. Scalable and measurable."</span>
        <span class="cs-proof-strip__source">— Leadstars</span>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="cs-closing">
    <div class="cs-closing__inner">
      <span class="label label--ghost-light">No cure no pay</span>
      <h2 class="cs-closing__title">
        Ready to be the next<br />success story?
      </h2>
      <p class="cs-closing__body">
        DetachPro, Van de Bilt Energy, and Leadstars went before you. Dozens of other companies did too. The only thing they have in common: they took action and booked a free intake.<br /><br />
        Your commercial breakthrough starts with one conversation.
      </p>
      <a href="/contact" class="btn btn--red btn--xl cs-closing__btn">Book your free intake →</a>
      <p class="cs-closing__sub">No obligations. No upfront costs. Just a clear picture of what is possible for your company.</p>
      <p class="cs-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .cs-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .cs-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .cs-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .cs-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .cs-hero__title-red { color: var(--color-red); }

  .cs-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .cs-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .cs-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Proof card rechts */
  .cs-hero__proof-card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-proof-header {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 20px;
  }

  .cs-proof-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
  }

  .cs-proof-item__logo-wrap {
    height: 44px;
    min-width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: var(--radius);
    flex-shrink: 0;
  }

  .cs-proof-item__logo-wrap--light { background: #f3f4f6; }
  .cs-proof-item__logo-wrap--dark { background: #1a1a1a; }

  .cs-proof-item__logo {
    height: 26px;
    width: auto;
    object-fit: contain;
    max-width: 100px;
  }

  .cs-proof-item__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-proof-item__result {
    font-size: 1.1rem;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .cs-proof-item__label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.3;
  }

  .cs-proof-divider {
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  @media (max-width: 960px) {
    .cs-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .cs-hero { padding: 100px 0 60px; }
    .cs-hero__actions { flex-direction: column; align-items: stretch; }
    .cs-hero__actions .btn { width: 100%; justify-content: center; }
  }

  /* ====================================================
     STATS BAR
  ==================================================== */
  .cs-statsbar {
    background: var(--color-black);
    padding: 40px 0;
  }

  .cs-statsbar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .cs-statsbar__stat {
    text-align: center;
  }

  .cs-statsbar__num {
    display: block;
    font-size: 1.8rem;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .cs-statsbar__label {
    display: block;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  .cs-statsbar__divider {
    width: 1px;
    height: 44px;
    background: rgba(255,255,255,0.1);
  }

  @media (max-width: 700px) {
    .cs-statsbar__divider { display: none; }
    .cs-statsbar__inner { gap: 28px; }
  }

  /* ====================================================
     CASES
  ==================================================== */
  .cs-cases { background: #F9FAFB; }

  .cs-cases__header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
  }

  .cs-cases__title {
    margin-top: 16px;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .cs-cases__title-red { color: var(--color-red); }

  .cs-cases__sub {
    font-size: 1rem;
    color: var(--color-gray-mid);
    line-height: 1.7;
  }

  .cs-cases__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    align-items: start;
  }

  .cs-case-card {
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .cs-case-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .cs-case-card--featured {
    border-color: var(--color-red);
    box-shadow: 0 0 0 1px var(--color-red);
  }

  .cs-case-card__header {
    padding: 28px 28px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--color-gray-border);
  }

  .cs-case-card--featured .cs-case-card__header {
    border-bottom-color: rgba(221,52,46,0.15);
  }

  .cs-case-card__logo-wrap {
    height: 48px;
    display: flex;
    align-items: center;
    padding: 6px 14px;
    border-radius: var(--radius);
    flex-shrink: 0;
  }

  .cs-case-card__logo-wrap--light { background: #f3f4f6; }
  .cs-case-card__logo-wrap--dark { background: #111; }

  .cs-case-card__logo {
    height: 28px;
    width: auto;
    object-fit: contain;
    max-width: 130px;
  }

  .cs-case-card__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }

  .cs-case-card__branche {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gray-mid);
  }

  .cs-case-card__badge {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
  }

  .cs-case-card__badge--green {
    background: rgba(16,185,129,0.1);
    color: #059669;
  }

  .cs-case-card__badge--red {
    background: var(--color-red);
    color: #fff;
  }

  .cs-case-card__body {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex: 1;
  }

  .cs-case-card__desc {
    font-size: 0.93rem;
    color: var(--color-gray-mid);
    line-height: 1.7;
  }

  .cs-case-section {
    display: flex;
    flex-direction: column;
