---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partnership — ClosersMatch" description="Bied je klanten meer, zonder extra werk of capaciteit. Word partner van ClosersMatch en verdien mee op elke deal die wordt gesloten.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="pn-hero">
    <div class="container pn-hero__inner">
      <div class="pn-hero__content">
        <span class="label label--red">Partnership</span>
        <h1 class="pn-hero__title">
          Bied je klanten meer.<br />
          <span class="pn-hero__title-red">Zonder er zelf meer voor te doen.</span>
        </h1>
        <p class="pn-hero__subtitle">
          Als marketingbureau, consultant of agency wil je meer voor je klanten kunnen betekenen. Via ClosersMatch voeg je professionele sales execution toe aan je dienstverlening, zonder zelf closers te werven, trainen of aan te sturen. Jij breidt je aanbod uit. Wij leveren de uitvoering. En op elke gerealiseerde deal verdien je mee.
        </p>
        <div class="pn-hero__trust-pills">
          <span class="trust-pill">✓ Meer waarde voor je klanten</span>
          <span class="trust-pill">✓ Geen extra werk of capaciteit</span>
          <span class="trust-pill">✓ Verdien mee op resultaat</span>
        </div>
        <div class="pn-hero__actions">
          <a href="/contact" class="btn btn--red btn--lg">Word partner →</a>
        </div>
      </div>

      <div class="pn-hero__visual">
        <div class="pn-hero__statement-card">
          <div class="pn-benefit">
            <div class="pn-benefit__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <div>
              <strong>Breder aanbod</strong>
              <span>Je biedt je klanten een compleet salestraject aan, naast jouw eigen dienstverlening.</span>
            </div>
          </div>
          <div class="pn-hero__statement-divider"></div>
          <div class="pn-benefit">
            <div class="pn-benefit__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <strong>Geen extra werk</strong>
              <span>Wij screenen, trainen en leveren de closers en setters. Jij hoeft niets op te schalen.</span>
            </div>
          </div>
          <div class="pn-hero__statement-divider"></div>
          <div class="pn-benefit pn-benefit--result">
            <div class="pn-benefit__icon pn-benefit__icon--red">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            </div>
            <div>
              <strong>Je verdient mee</strong>
              <span>Op elke deal die wordt gesloten ontvang je een terugkerend aandeel in de omzet.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       VOOR WIE
  ================================================ -->
  <section class="section pn-voorwie">
    <div class="container">
      <div class="pn-voorwie__header">
        <span class="label">Voor wie</span>
        <h2 class="h2 pn-voorwie__title">Gebouwd voor partijen die leads en campagnes leveren.</h2>
      </div>

      <div class="pn-voorwie__grid">
        <div class="pn-voorwie__card">
          <div class="pn-voorwie__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="pn-voorwie__card-title">Marketingbureaus</h3>
          <p class="pn-voorwie__card-text">Je genereert leads en traffic voor klanten, maar de closing gebeurt intern of helemaal niet. Wij nemen dat stuk over.</p>
        </div>
        <div class="pn-voorwie__card">
          <div class="pn-voorwie__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="pn-voorwie__card-title">Consultants</h3>
          <p class="pn-voorwie__card-text">Je adviseert klanten over groei en strategie. Wij voegen de uitvoerende salescapaciteit toe die jouw advies waarmaakt.</p>
        </div>
        <div class="pn-voorwie__card">
          <div class="pn-voorwie__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="pn-voorwie__card-title">Agencies</h3>
          <p class="pn-voorwie__card-text">Je bedient klanten op zichtbaarheid en leadgeneratie. Voeg sales execution toe zonder zelf een team op te bouwen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       TWEE SAMENWERKINGSVORMEN
  ================================================ -->
  <section class="section pn-vormen">
    <div class="container">
      <div class="pn-vormen__header">
        <span class="label label--red">Twee samenwerkingsvormen</span>
        <h2 class="h2 pn-vormen__title">Kies de vorm die bij jouw klanten past.</h2>
      </div>

      <div class="pn-vormen__grid">
        <div class="pn-vorm-card">
          <div class="pn-vorm-card__num">01</div>
          <h3 class="pn-vorm-card__title">Klanten doorverwijzen</h3>
          <p class="pn-vorm-card__text">Je brengt ons in contact met klanten die salesondersteuning nodig hebben. Wij nemen het volledige traject over, van intake tot gesloten deal. Jij ontvangt een terugkerende commissie op elke deal die wordt gesloten.</p>
          <ul class="pn-vorm-card__list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Minimale inspanning van jouw kant
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Terugkerende commissie per gesloten deal
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Wij verzorgen het volledige salestraject
            </li>
          </ul>
        </div>

        <div class="pn-vorm-card pn-vorm-card--featured">
          <span class="pn-vorm-card__badge">Meest gekozen</span>
          <div class="pn-vorm-card__num">02</div>
          <h3 class="pn-vorm-card__title">Samen bedienen</h3>
          <p class="pn-vorm-card__text">Je blijft eigenaar van de klantrelatie en levert leadgeneratie of marketing. ClosersMatch voegt de closers en setters toe die de sales uitvoeren. Eén geïntegreerd aanbod, gedeelde opbrengst.</p>
          <ul class="pn-vorm-card__list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Jij behoudt de klantrelatie
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Eén geïntegreerd aanbod richting de klant
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Revenue share op de gerealiseerde omzet
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT
  ================================================ -->
  <section class="section pn-hiw">
    <div class="container">
      <div class="pn-hiw__header">
        <span class="label">Het proces</span>
        <h2 class="h2 pn-hiw__title">Van aanmelding tot eerste gedeelde omzet.</h2>
      </div>

      <div class="pn-hiw__grid">
        <div class="pn-hiw__step">
          <div class="pn-hiw__step-num">01</div>
          <h3 class="pn-hiw__step-title">Aanmelden</h3>
          <p class="pn-hiw__step-text">Je vertelt ons over je bureau, klanten en manier van werken via het aanmeldformulier.</p>
        </div>
        <div class="pn-hiw__step">
          <div class="pn-hiw__step-num">02</div>
          <h3 class="pn-hiw__step-title">Partnergesprek</h3>
          <p class="pn-hiw__step-text">We bespreken samen welke samenwerkingsvorm past en stellen de voorwaarden en revenue share vast.</p>
        </div>
        <div class="pn-hiw__step">
          <div class="pn-hiw__step-num">03</div>
          <h3 class="pn-hiw__step-title">Klanten koppelen</h3>
          <p class="pn-hiw__step-text">Je verwijst klanten door of we bedienen ze samen, afhankelijk van de gekozen vorm.</p>
        </div>
        <div class="pn-hiw__step">
          <div class="pn-hiw__step-num">04</div>
          <h3 class="pn-hiw__step-title">Omzet delen</h3>
          <p class="pn-hiw__step-text">Voor elke gerealiseerde deal ontvang je jouw aandeel. Transparant en doorlopend.</p>
        </div>
      </div>

      <div class="pn-hiw__cta">
        <a href="/contact" class="btn btn--red btn--lg">Plan een partnergesprek →</a>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAAROM PARTNEREN MET CLOSERSMATCH
  ================================================ -->
  <section class="section pn-waarom">
    <div class="container pn-waarom__inner">
      <div class="pn-waarom__content">
        <span class="label label--red">Waarom ClosersMatch</span>
        <h2 class="h2 pn-waarom__title">Voeg sales execution toe zonder zelf een team op te bouwen.</h2>
        <p class="pn-waarom__body">Je hoeft geen closers aan te nemen, te trainen of aan te sturen. Wij leveren gecertificeerde professionals die klaarstaan om jouw klanten te bedienen, op no cure no pay basis. Jij blijft doen waar je goed in bent: leads en campagnes.</p>
      </div>

      <div class="pn-waarom__blocks">
        <div class="pn-waarom__block">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Geen wervingskosten of personeelsrisico</span>
        </div>
        <div class="pn-waarom__block">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Gecertificeerde, gescreende closers en setters</span>
        </div>
        <div class="pn-waarom__block">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Extra dienst zonder extra vaste kosten</span>
        </div>
        <div class="pn-waarom__block">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Terugkerende, schaalbare inkomsten</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="pn-closing">
    <div class="pn-closing__inner">
      <span class="label label--ghost-light">Partnership</span>
      <h2 class="pn-closing__title">
        Jij brengt de klanten.<br />Wij sluiten de deals.
      </h2>
      <p class="pn-closing__body">
        Samen zetten we campagnes om in omzet. Meld je aan als partner en ontdek welke samenwerkingsvorm bij jou past.
      </p>
      <a href="/contact" class="btn btn--red btn--xl pn-closing__btn">Word partner →</a>
      <p class="pn-closing__sub">Geen verplichtingen. Binnen 48 uur een reactie.</p>
      <p class="pn-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .pn-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .pn-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .pn-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .pn-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .pn-hero__title-red { color: var(--color-red); }

  .pn-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 540px;
  }

  .pn-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .pn-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Statement card */
  .pn-hero__statement-card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
  }

  .pn-benefit {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
    align-items: flex-start;
    padding: 18px 0;
  }

  .pn-benefit__icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.6);
    flex-shrink: 0;
  }

  .pn-benefit__icon--red {
    background: rgba(221,52,46,0.2);
    color: var(--color-red);
  }

  .pn-benefit strong {
    display: block;
    font-size: 0.98rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
    font-family: var(--font-display);
  }

  .pn-benefit span {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.55;
  }

  .pn-benefit--result strong { color: var(--color-red); }

  .pn-hero__statement-divider {
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  @media (max-width: 960px) {
    .pn-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .pn-hero { padding: 100px 0 60px; }
    .pn-hero__actions .btn { width: 100%; justify-content: center; }
  }

  /* ====================================================
     VOOR WIE
  ==================================================== */
  .pn-voorwie { background: #F9FAFB; }

  .pn-voorwie__header {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 56px;
  }

  .pn-voorwie__title {
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .pn-voorwie__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .pn-voorwie__card {
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pn-voorwie__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .pn-voorwie__icon {
    width: 46px;
    height: 46px;
    background: rgba(221,52,46,0.08);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-red);
    margin-bottom: 20px;
  }

  .pn-voorwie__card-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-black);
    margin-bottom: 10px;
    font-family: var(--font-display);
  }

  .pn-voorwie__card-text {
    font-size: 0.9rem;
    color: var(--color-gray-mid);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .pn-voorwie__grid { grid-template-columns: 1fr; }
  }

  /* ====================================================
     TWEE SAMENWERKINGSVORMEN
  ==================================================== */
  .pn-vormen { background: #fff; }

  .pn-vormen__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  .pn-vormen__title {
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .pn-vormen__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 960px;
    margin: 0 auto;
  }

  .pn-vorm-card {
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #F9FAFB;
  }

  .pn-vorm-card--featured {
    background: #fff;
    border-color: var(--color-red);
    box-shadow: 0 0 0 1px var(--color-red), var(--shadow);
  }

  .pn-vorm-card__badge {
    position: absolute;
    top: -13px;
    right: 28px;
    background: var(--color-red);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
  }

  .pn-vorm-card__num {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-red);
    font-family: var(--font-display);
  }

  .pn-vorm-card__title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-black);
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }

  .pn-vorm-card__text {
    font-size: 0.92rem;
    color: var(--color-gray-mid);
    line-height: 1.7;
  }

  .pn-vorm-card__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pn-vorm-card__list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .pn-vorm-card__list li svg { color: var(--color-red); flex-shrink: 0; }

  @media (max-width: 800px) {
    .pn-vormen__grid { grid-template-columns: 1fr; }
  }

  /* ====================================================
     HOE HET WERKT
  ==================================================== */
  .pn-hiw { background: #F9FAFB; }

  .pn-hiw__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  .pn-hiw__title {
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .pn-hiw__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .pn-hiw__step {
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pn-hiw__step:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .pn-hiw__step-num {
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: #fff;
    background: var(--color-red);
    border-radius: 999px;
    padding: 3px 9px;
    display: inline-block;
    margin-bottom: 16px;
  }

  .pn-hiw__step-title {
    font-size: 1.02rem;
    font-weight: 800;
    color: var(--color-black);
    margin-bottom: 10px;
    font-family: var(--font-display);
  }

  .pn-hiw__step-text {
    font-size: 0.87rem;
    color: var(--color-gray-mid);
    line-height: 1.65;
  }

  .pn-hiw__cta { text-align: center; }

  @media (max-width: 960px) {
    .pn-hiw__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .pn-hiw__grid { grid-template-columns: 1fr; }
  }

  /* ====================================================
     WAAROM
  ==================================================== */
  .pn-waarom { background: #fff; }

  .pn-waarom__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .pn-waarom__title {
    margin-top: 16px;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

