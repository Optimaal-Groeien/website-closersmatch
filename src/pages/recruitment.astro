---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sales Recruitment — ClosersMatch" description="Sales recruitment zonder HR-risico. Geen wervingskosten, geen vast salaris, no cure no pay. ClosersMatch levert ervaren closers en appointment setters die direct inzetbaar zijn.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="rc-hero">
    <div class="container rc-hero__inner">
      <div class="rc-hero__content">
        <span class="label label--red">Sales Recruitment</span>
        <h1 class="rc-hero__title">
          Schaal je salesteam op.<br />
          <span class="rc-hero__title-red">Zonder personeelsrisico.</span>
        </h1>
        <p class="rc-hero__subtitle">
          Traditionele werving kost maanden en brengt geen garantie. ClosersMatch levert ervaren closers en appointment setters die direct inzetbaar zijn — op no cure no pay basis.
        </p>
        <div class="rc-hero__trust-pills">
          <span class="trust-pill">✓ Geen wervingskosten</span>
          <span class="trust-pill">✓ Operationeel binnen dagen</span>
          <span class="trust-pill">✓ No cure no pay</span>
        </div>
        <div class="rc-hero__actions">
          <a href="/contact" class="btn btn--red btn--lg">Plan je gratis intake →</a>
        </div>
      </div>
      <div class="rc-hero__visual">
        <div class="rc-compare-card">
          <div class="rc-compare-card__col rc-compare-card__col--old">
            <div class="rc-compare-card__heading">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Traditionele werving
            </div>
            <ul class="rc-compare-card__list">
              <li class="rc-compare-card__item rc-compare-card__item--no">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Weken tot maanden
              </li>
              <li class="rc-compare-card__item rc-compare-card__item--no">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Vast salaris ongeacht prestaties
              </li>
              <li class="rc-compare-card__item rc-compare-card__item--no">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Hoog werkgeversrisico
              </li>
            </ul>
          </div>
          <div class="rc-compare-card__col rc-compare-card__col--new">
            <div class="rc-compare-card__heading rc-compare-card__heading--new">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              ClosersMatch
            </div>
            <ul class="rc-compare-card__list">
              <li class="rc-compare-card__item rc-compare-card__item--yes">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Operationeel binnen dagen
              </li>
              <li class="rc-compare-card__item rc-compare-card__item--yes">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Betalen alleen bij resultaat
              </li>
              <li class="rc-compare-card__item rc-compare-card__item--yes">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Geen werkgeversrisico
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       PROBLEEM SECTIE
  ================================================ -->
  <section class="section rc-pijn">
    <div class="container">
      <div class="rc-pijn__header">
        <span class="label">Het recruitmentprobleem</span>
        <h2 class="h2 rc-pijn__title">Maanden zoeken. Duur trainen.<br /><span class="rc-pijn__title-red">En dan hopen dat het werkt.</span></h2>
        <p class="rc-pijn__sub">Terwijl jij wacht op de juiste kandidaat, lopen leads dood, gaan kansen verloren en vertraagt je groei. De traditionele wervingsprocedure is niet alleen langzaam — ze brengt ook geen garantie op commercieel resultaat.</p>
      </div>

      <div class="rc-pijn__grid">
        <div class="rc-pijn__item">
          <div class="rc-pijn__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <div>
            <h3 class="rc-pijn__item-title">Wervingsprocedure duurt 3-6 maanden</h3>
            <p class="rc-pijn__item-text">Vacature plaatsen, cv's beoordelen, gesprekken voeren, aanbod doen — en ondertussen staat je salesafdeling stil.</p>
          </div>
        </div>
        <div class="rc-pijn__item">
          <div class="rc-pijn__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <div>
            <h3 class="rc-pijn__item-title">Vast salaris ongeacht prestaties</h3>
            <p class="rc-pijn__item-text">Je betaalt maandelijks een vast bedrag, ongeacht hoeveel deals er worden gesloten. Het financiële risico ligt volledig bij jou.</p>
          </div>
        </div>
        <div class="rc-pijn__item">
          <div class="rc-pijn__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <h3 class="rc-pijn__item-title">Onboarding en training kost extra tijd & geld</h3>
            <p class="rc-pijn__item-text">Na de aanwerving begint het echte werk pas: inwerken, trainen, begeleiden. Maanden voordat iemand productief is.</p>
          </div>
        </div>
        <div class="rc-pijn__item">
          <div class="rc-pijn__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <div>
            <h3 class="rc-pijn__item-title">Geen garantie op commerciële resultaten</h3>
            <p class="rc-pijn__item-text">Na al die investering is er nog steeds geen zekerheid. Iemand die goed interviewt, sluit niet automatisch goed deals.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       OPLOSSING
  ================================================ -->
  <section class="section rc-opl">
    <div class="container">
      <div class="rc-opl__header">
        <span class="label">De ClosersMatch aanpak</span>
        <h2 class="h2 rc-opl__title">Ervaren salesprofessionals. Direct inzetbaar.<br /><span class="rc-opl__title-red">Betaal alleen bij resultaat.</span></h2>
      </div>

      <div class="rc-opl__grid">
        <div class="rc-opl__feature">
          <div class="rc-opl__feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="rc-opl__feature-title">Gescreend talent</h3>
          <p class="rc-opl__feature-text">Elke closer en setter wordt beoordeeld op saleservaring, communicatieve vaardigheden en commerciële trackrecord. Geen giswerk — alleen bewezen professionals.</p>
        </div>
        <div class="rc-opl__feature">
          <div class="rc-opl__feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="rc-opl__feature-title">Branche-afstemming</h3>
          <p class="rc-opl__feature-text">We koppelen op markt, doelgroep, salesstijl en dealgrootte. Geen generieke matches — een professional die begrijpt wat jouw klant nodig heeft.</p>
        </div>
        <div class="rc-opl__feature">
          <div class="rc-opl__feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="rc-opl__feature-title">Snelle implementatie</h3>
          <p class="rc-opl__feature-text">De meeste bedrijven zijn binnen enkele dagen operationeel. Niet maanden. Onboarding is inbegrepen en volledig gratis.</p>
        </div>
        <div class="rc-opl__feature">
          <div class="rc-opl__feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="rc-opl__feature-title">Prestatiegericht model</h3>
          <p class="rc-opl__feature-text">Ons ecosysteem is gebouwd rond resultaten. Jij betaalt alleen als er geleverd wordt. Geen resultaat, geen kosten — zo eenvoudig is het.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT — 3 STAPPEN
  ================================================ -->
  <section class="section rc-hiw">
    <div class="container">
      <div class="rc-hiw__header">
        <span class="label">In 3 stappen</span>
        <h2 class="h2 rc-hiw__title">Van opdracht tot eerste deal.</h2>
      </div>

      <div class="rc-hiw__grid">
        <div class="rc-hiw__step">
          <div class="rc-hiw__step-num">01</div>
          <h3 class="rc-hiw__step-title">Opdracht plaatsen</h3>
          <p class="rc-hiw__step-text">Vertel ons over je bedrijf, doelgroep en salesproces. We stellen een profiel op voor de ideale match — closer, setter of een combinatie van beiden.</p>
        </div>
        <div class="rc-hiw__step">
          <div class="rc-hiw__step-num">02</div>
          <h3 class="rc-hiw__step-title">Matching</h3>
          <p class="rc-hiw__step-text">Binnen 48 uur koppelen we je aan gecertificeerde closers en setters die aansluiten bij jouw markt, salesstijl en dealgrootte. Geen stapels cv's, geen sollicitatiegesprekken.</p>
        </div>
        <div class="rc-hiw__step">
          <div class="rc-hiw__step-num">03</div>
          <h3 class="rc-hiw__step-title">Start & schaal</h3>
          <p class="rc-hiw__step-text">Directe inzetbaarheid. Onboarding inbegrepen. Jij focust op groei, wij zorgen voor de juiste mensen die jouw salesproces overnemen en resultaat leveren.</p>
        </div>
      </div>

      <div class="rc-hiw__cta">
        <a href="/contact" class="btn btn--red btn--lg">Plan je gratis intake →</a>
      </div>
    </div>
  </section>

  <!-- ================================================
       VERGELIJKING TABEL
  ================================================ -->
  <section class="section rc-waarom">
    <div class="container">
      <div class="rc-waarom__header">
        <span class="label">Waarom ClosersMatch</span>
        <h2 class="h2 rc-waarom__title">Traditionele werving vs. ClosersMatch Recruitment.</h2>
      </div>

      <div class="rc-waarom__compare">

        <!-- Traditioneel -->
        <div class="vb-compare-col vb-compare-col--old">
          <div class="vb-compare-col__header">
            <span class="vb-compare-col__tag vb-compare-col__tag--gray">Traditionele werving</span>
          </div>
          <ul class="vb-compare-list">
            <li class="vb-compare-item vb-compare-item--no">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Wervingskosten
            </li>
            <li class="vb-compare-item vb-compare-item--no">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Lang sollicitatieproces
            </li>
            <li class="vb-compare-item vb-compare-item--no">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Vaste salarissen
            </li>
            <li class="vb-compare-item vb-compare-item--no">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Inwerkperiode
            </li>
            <li class="vb-compare-item vb-compare-item--no">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Geen resultaatgarantie
            </li>
            <li class="vb-compare-item vb-compare-item--no">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Werkgeversrisico
            </li>
          </ul>
        </div>

        <!-- vs -->
        <div class="vb-compare-vs">VS</div>

        <!-- ClosersMatch -->
        <div class="vb-compare-col vb-compare-col--new">
          <div class="vb-compare-col__header">
            <span class="vb-compare-col__tag vb-compare-col__tag--red">ClosersMatch</span>
          </div>
          <ul class="vb-compare-list">
            <li class="vb-compare-item vb-compare-item--yes">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Geen wervingskosten
            </li>
            <li class="vb-compare-item vb-compare-item--yes">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Match binnen 48 uur
            </li>
            <li class="vb-compare-item vb-compare-item--yes">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              No cure no pay
            </li>
            <li class="vb-compare-item vb-compare-item--yes">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Gratis onboarding inbegrepen
            </li>
            <li class="vb-compare-item vb-compare-item--yes">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Gecertificeerde professionals
            </li>
            <li class="vb-compare-item vb-compare-item--yes">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Schaalbaar zonder risico
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       FAQ
  ================================================ -->
  <section class="section rc-faq">
    <div class="container">
      <div class="rc-faq__header">
        <span class="label">Veelgestelde vragen</span>
        <h2 class="h2 rc-faq__title">Alles wat je wilt weten over sales recruitment via ClosersMatch.</h2>
      </div>

      <div class="rc-faq__grid">
        <div class="rc-faq__item">
          <h3 class="rc-faq__q">Hoe waarborgen jullie de kwaliteit van closers?</h3>
          <p class="rc-faq__a">Elke closer doorloopt een screening en de CM Certified training voordat hij of zij toegang krijgt tot opdrachten. We toetsen op saleservaring, communicatieve vaardigheden en commerciële prestaties.</p>
        </div>
        <div class="rc-faq__item">
          <h3 class="rc-faq__q">Kunnen closers werken in ons CRM?</h3>
          <p class="rc-faq__a">Ja. Closers worden ingewerkt op jouw bestaande systemen, processen en workflows. CRM-integratie is standaard onderdeel van de onboarding.</p>
        </div>
        <div class="rc-faq__item">
          <h3 class="rc-faq__q">Voor welke sectoren werkt dit?</h3>
          <p class="rc-faq__a">B2B-dienstverlening, SaaS, consultancy, bureaus en high-ticket services. Heeft jouw branche een specifieke salesaanpak? We matchen op branche en dealgrootte.</p>
        </div>
        <div class="rc-faq__item">
          <h3 class="rc-faq__q">Wat als het niet werkt?</h3>
          <p class="rc-faq__a">Dan betaal je niets. No cure no pay is geen marketingterm — het is hoe ons model werkt. Geen resultaat, geen kosten.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="rc-closing">
    <div class="rc-closing__inner">
      <span class="label label--ghost-light">No cure no pay</span>
      <h2 class="rc-closing__title">
        Stop met zoeken.<br />Begin met sluiten.
      </h2>
      <p class="rc-closing__body">
        ClosersMatch levert gescreende, gecertificeerde salesprofessionals die direct inzetbaar zijn. Geen wervingsrisico. Geen vast salaris. Alleen resultaat.
      </p>
      <a href="/contact" class="btn btn--red btn--xl rc-closing__btn">Plan je gratis intake →</a>
      <p class="rc-closing__sub">Geen verplichtingen. Geen kosten vooraf.</p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .rc-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .rc-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .rc-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .rc-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .rc-hero__title-red { color: var(--color-red); }

  .rc-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .rc-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .rc-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Comparison card on the right */
  .rc-compare-card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .rc-compare-card__col {
    padding: 28px 24px;
  }

  .rc-compare-card__col--old {
    border-right: 1px solid rgba(255,255,255,0.08);
  }

  .rc-compare-card__heading {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .rc-compare-card__heading--new {
    color: rgba(255,255,255,0.9);
  }

  .rc-compare-card__heading--new svg {
    color: #4ade80;
  }

  .rc-compare-card__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .rc-compare-card__item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .rc-compare-card__item svg { flex-shrink: 0; margin-top: 1px; }

