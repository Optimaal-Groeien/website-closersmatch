---
import Layout from '../../layouts/Layout.astro';
---

<Layout locale="en" title="Werkwijze — ClosersMatch" description="Ontdek hoe ClosersMatch werkt. Van eerste lead tot gesloten deal — gecertificeerde closers, appointment setters, AI-coaching en real-time inzicht in één prestatiegericht model.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="ww-hero">
    <div class="container ww-hero__inner">
      <div class="ww-hero__content">
        <span class="label label--red">Werkwijze</span>
        <h1 class="ww-hero__title">
          Van eerste lead tot<br />
          gesloten deal.<br />
          <span class="ww-hero__title-red">Zo werkt het.</span>
        </h1>
        <p class="ww-hero__subtitle">
          ClosersMatch is geen marktplaats. Het is een beheerd commercieel ecosysteem. Wij combineren gecertificeerde closers, appointment setters, AI-coaching en real-time inzicht in één prestatiegericht model — van lead tot deal.
        </p>
        <div class="ww-hero__trust-pills">
          <span class="trust-pill">Ô£ô No cure no pay</span>
          <span class="trust-pill">Ô£ô Match binnen 48 uur</span>
          <span class="trust-pill">Ô£ô Volledig inzicht</span>
        </div>
        <div class="ww-hero__actions">
          <a href="/en/contact" class="btn btn--red btn--lg">Plan je gratis intake →</a>
        </div>
      </div>
      <div class="ww-hero__visual">
        <div class="ww-hero__card">
          <p class="ww-hero__card-heading">Wat je krijgt:</p>
          <ul class="ww-hero__card-list">
            <li class="ww-hero__card-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Gecertificeerde closers
            </li>
            <li class="ww-hero__card-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Appointment setters
            </li>
            <li class="ww-hero__card-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              AI-coaching
            </li>
            <li class="ww-hero__card-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              CRM-integratie
            </li>
            <li class="ww-hero__card-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Pipeline inzicht
            </li>
            <li class="ww-hero__card-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Doorlopende optimalisatie
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       MEER DAN EEN MARKTPLAATS
  ================================================ -->
  <section class="section ww-eco">
    <div class="container ww-eco__inner">
      <div class="ww-eco__content">
        <span class="label">Het ecosysteem</span>
        <h2 class="h2 ww-eco__title">Eén systeem. Van lead tot deal.<br />Eén verantwoordelijke.</h2>
        <p class="ww-eco__body">
          ClosersMatch is geen freelanceplatform waar jij zelf moet filteren, aansturen en hopen op resultaat. Het is een beheerd ecosysteem waarbij gekwalificeerde closers, appointment setters, AI-coaching en real-time rapportages samenwerken in één prestatiegericht model. Jij focust op je bedrijf. Wij sluiten de deals.
        </p>
        <p class="ww-eco__body">
          Eén aanspreekpunt. Volledige verantwoordelijkheid. Schaalbaar zonder risico.
        </p>
      </div>
      <div class="ww-eco__compare">
        <div class="ww-eco__compare-item">
          <div class="ww-eco__compare-no">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Losse freelancers zonder structuur
          </div>
          <div class="ww-eco__compare-arrow">→</div>
          <div class="ww-eco__compare-yes">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Beheerd ecosysteem met coaching
          </div>
        </div>
        <div class="ww-eco__compare-item">
          <div class="ww-eco__compare-no">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Geen inzicht in prestaties
          </div>
          <div class="ww-eco__compare-arrow">→</div>
          <div class="ww-eco__compare-yes">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Real-time dashboard &amp; rapportages
          </div>
        </div>
        <div class="ww-eco__compare-item">
          <div class="ww-eco__compare-no">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Betalen zonder garantie
          </div>
          <div class="ww-eco__compare-arrow">→</div>
          <div class="ww-eco__compare-yes">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            No cure no pay model
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       7-STAPPEN WERKWIJZE
  ================================================ -->
  <section class="section ww-steps">
    <div class="container">
      <div class="ww-steps__header">
        <span class="label">Het proces</span>
        <h2 class="h2 ww-steps__title">Zeven stappen naar<br />structurele omzetgroei.</h2>
      </div>

      <div class="ww-steps__timeline">

        <div class="ww-step">
          <div class="ww-step__left">
            <div class="ww-step__circle">01</div>
            <div class="ww-step__line"></div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Intake &amp; kwalificatie</h3>
            <p class="ww-step__text">We leren je bedrijf, aanbod en groeidoelstellingen kennen. We beoordelen het commercieel potentieel en stellen de juiste aanpak voor.</p>
          </div>
        </div>

        <div class="ww-step">
          <div class="ww-step__left">
            <div class="ww-step__circle">02</div>
            <div class="ww-step__line"></div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Commerci├½le analyse</h3>
            <p class="ww-step__text">We stellen het ideale profiel vast: markt, dealgrootte, doelgroep en verkoopcyclus. Zo is elke match strategisch — geen giswerk.</p>
          </div>
        </div>

        <div class="ww-step">
          <div class="ww-step__left">
            <div class="ww-step__circle">03</div>
            <div class="ww-step__line"></div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Matching met gecertificeerd talent</h3>
            <p class="ww-step__text">Je wordt gekoppeld aan closers en setters die jouw branche, doelgroep en salesproces door en door kennen. Gescreend en gecertificeerd. Binnen 48 uur.</p>
          </div>
        </div>

        <div class="ww-step">
          <div class="ww-step__left">
            <div class="ww-step__circle">04</div>
            <div class="ww-step__line"></div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Actieve opvolging &amp; closing</h3>
            <p class="ww-step__text">De closer neemt contact op, voert gesprekken en volgt kansen op. Geen gemiste leads. Geen stilstaande pipeline. Elke kans wordt benut.</p>
          </div>
        </div>

        <div class="ww-step">
          <div class="ww-step__left">
            <div class="ww-step__circle">05</div>
            <div class="ww-step__line"></div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Transparante afhandeling</h3>
            <p class="ww-step__text">Gesloten deals worden bijgehouden via het ClosersMatch-ecosysteem. Transparant voor bedrijven én professionals. Altijd inzicht, altijd controle.</p>
          </div>
        </div>

        <div class="ww-step">
          <div class="ww-step__left">
            <div class="ww-step__circle">06</div>
            <div class="ww-step__line"></div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Optimalisatie &amp; bijsturing</h3>
            <p class="ww-step__text">Gesprekken, afspraken, pipeline-waarde en omzet worden continu gemonitord. Meer data. Betere beslissingen. Hogere conversie.</p>
          </div>
        </div>

        <div class="ww-step ww-step--last">
          <div class="ww-step__left">
            <div class="ww-step__circle ww-step__circle--last">07</div>
          </div>
          <div class="ww-step__body">
            <h3 class="ww-step__title">Schalen zonder risico</h3>
            <p class="ww-step__text">Meer capaciteit nodig? Voeg extra closers of setters toe zonder dat loonkosten stijgen. Schaal wanneer het jou uitkomt — op no cure no pay.</p>
          </div>
        </div>

      </div>

      <div class="ww-steps__cta">
        <a href="/en/contact" class="btn btn--red btn--lg">Plan je gratis intake →</a>
      </div>
    </div>
  </section>

  <!-- ================================================
       VOOR WIE
  ================================================ -->
  <section class="section ww-voorwie">
    <div class="container">
      <div class="ww-voorwie__header">
        <span class="label">Voor wie</span>
        <h2 class="h2 ww-voorwie__title">Eén ecosysteem. Drie doelgroepen.</h2>
      </div>

      <div class="ww-voorwie__grid">

        <div class="ww-voorwie__card ww-voorwie__card--featured">
          <div class="ww-voorwie__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <h3 class="ww-voorwie__card-title">Voor Bedrijven</h3>
          <p class="ww-voorwie__card-text">Meer afspraken, gesprekken en klanten zonder extra personeel. Ideaal voor B2B-bedrijven, bureaus, consultants, SaaS en high-ticket services.</p>
          <a href="/en/for-businesses" class="ww-voorwie__card-link">Bekijk voor bedrijven →</a>
        </div>

        <div class="ww-voorwie__card">
          <div class="ww-voorwie__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="ww-voorwie__card-title">Voor Closers</h3>
          <p class="ww-voorwie__card-text">Toegang tot serieuze kansen en gekwalificeerde leads. Focus op sluiten, wij regelen de rest. Gecertificeerd, erkend en doorlopend gecoacht.</p>
          <a href="/en/for-closers" class="ww-voorwie__card-link">Bekijk voor closers →</a>
        </div>

        <div class="ww-voorwie__card">
          <div class="ww-voorwie__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="22 11 22 13"/><line x1="20" y1="12" x2="24" y2="12"/></svg>
          </div>
          <h3 class="ww-voorwie__card-title">Voor Partners</h3>
          <p class="ww-voorwie__card-text">Breng bedrijven in contact met het ecosysteem en verdien terugkerende commissies op prestatiebasis. Samen bouwen aan meer omzet.</p>
          <a href="/en/contact" class="ww-voorwie__card-link">Bekijk partnership →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       VOLLEDIG INZICHT
  ================================================ -->
  <section class="section ww-inzicht">
    <div class="container ww-inzicht__inner">
      <div class="ww-inzicht__content">
        <span class="label">Inzicht &amp; controle</span>
        <h2 class="h2 ww-inzicht__title">Jij ziet alles. Altijd.</h2>
        <p class="ww-inzicht__body">
          De meeste bedrijven weten niet welke leads er zijn benaderd, welke gesprekken er lopen of waarom deals blijven hangen. Dat gebrek aan inzicht kost omzet — elke dag opnieuw.
        </p>
        <p class="ww-inzicht__body">
          ClosersMatch geeft je volledige zichtbaarheid in je commercieel proces. Geen black box. Geen giswerk. Alleen heldere data en real-time rapportages zodat jij de juiste beslissingen neemt.
        </p>
      </div>
      <div class="ww-inzicht__card">
        <p class="ww-inzicht__card-heading">Wat je bijhoudt in real-time:</p>
        <ul class="ww-inzicht__card-list">
          <li class="ww-inzicht__card-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Leads &amp; eerste contacten
          </li>
          <li class="ww-inzicht__card-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Gevoerde gesprekken &amp; calls
          </li>
          <li class="ww-inzicht__card-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Ingeplande afspraken
          </li>
          <li class="ww-inzicht__card-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Pipeline-waarde
          </li>
          <li class="ww-inzicht__card-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Gesloten deals
          </li>
          <li class="ww-inzicht__card-item ww-inzicht__card-item--highlight">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Omzet — in real-time
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAAROM CLOSERSMATCH
  ================================================ -->
  <section class="section ww-waarom">
    <div class="container">
      <div class="ww-waarom__header">
        <span class="label">Waarom ClosersMatch</span>
        <h2 class="h2 ww-waarom__title">Gebouwd voor serieuze B2B-sales.<br />Zonder chaos.</h2>
      </div>

      <div class="ww-waarom__grid">

        <div class="ww-waarom__card">
          <div class="ww-waarom__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="ww-waarom__card-title">Geen open marktplaats</h3>
          <p class="ww-waarom__card-text">Elke closer is gescreend en gecertificeerd. Geen willekeurige freelancers — alleen bewezen professionals die resultaat leveren.</p>
        </div>

        <div class="ww-waarom__card">
          <div class="ww-waarom__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="ww-waarom__card-title">Geen onervaren verkopers</h3>
          <p class="ww-waarom__card-text">Ervaring, professionaliteit en aantoonbare prestaties staan voorop. Geen starters die op jouw kosten leren — alleen senioren die direct performen.</p>
        </div>

        <div class="ww-waarom__card">
          <div class="ww-waarom__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <h3 class="ww-waarom__card-title">Geen vaste salarissen</h3>
          <p class="ww-waarom__card-text">Uitbreiden zonder personeelsrisico. Betaal alleen bij resultaat. Geen arbeidscontracten, geen werkgeverslasten, geen ontslagprocedures.</p>
        </div>

        <div class="ww-waarom__card">
          <div class="ww-waarom__card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="ww-waarom__card-title">Geen gemiste kansen</h3>
          <p class="ww-waarom__card-text">Consistente opvolging zorgt dat meer leads worden omgezet in klanten. Elk contactmoment wordt benut — niets valt tussen de wal en het schip.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       CLOSING CTA
  ================================================ -->
  <section class="ww-closing">
    <div class="ww-closing__inner">
      <span class="label ww-closing__label">No cure no pay</span>
      <h2 class="ww-closing__title">
        Klaar om meer leads<br />om te zetten in klanten?
      </h2>
      <p class="ww-closing__body">
        Of je nu zoekt naar een closer, extra salescapaciteit of een compleet commercieel systeem — ClosersMatch bouwt het voor jou. Op no cure no pay.
      </p>
      <a href="/en/contact" class="btn btn--red btn--xl ww-closing__btn">Plan je gratis intake →</a>
      <p class="ww-closing__sub">Geen verplichtingen. Geen kosten vooraf.</p>
      <p class="ww-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .ww-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .ww-hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .ww-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .ww-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .ww-hero__title-red { color: var(--color-red); }

  .ww-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .ww-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .ww-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Dark card right side */
  .ww-hero__card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
  }

  .ww-hero__card-heading {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ww-hero__card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ww-hero__card-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
  }

  .ww-hero__card-item svg {
    color: #4ade80;
    flex-shrink: 0;
  }

  @media (max-width: 960px) {
    .ww-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .ww-hero { padding: 100px 0 60px; }
    .ww-hero__actions { flex-direction: column; align-items: stretch; }
