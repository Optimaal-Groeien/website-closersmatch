---
import Layout from '../../layouts/Layout.astro';
---

<Layout locale="en" title="For Sales Talent — ClosersMatch" description="ClosersMatch is a performance-driven ecosystem for ambitious sales professionals. Certified training, vetted companies, and assignments that fit you, as a closer or appointment setter.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="vst-hero">
    <div class="container vst-hero__inner">
      <div class="vst-hero__content">
        <span class="label label--red">For sales talent</span>
        <h1 class="vst-hero__title">
          Companies are ready.<br />
          You close, or open the door.
        </h1>
        <p class="vst-hero__subtitle">
          ClosersMatch is not a job board. It is a performance-driven ecosystem for ambitious sales professionals. Certified training, vetted companies, and assignments that truly fit you, whether you close deals or book appointments.
        </p>
        <div class="vst-hero__trust-pills">
          <span class="trust-pill">✓ CM Certified training</span>
          <span class="trust-pill">✓ Vetted companies</span>
          <span class="trust-pill">✓ Tailored matching</span>
        </div>
        <div class="vst-hero__actions">
          <a href="/en/for-closers" class="btn btn--red btn--lg">Become a closer →</a>
          <a href="/en/for-appointment-setters" class="btn btn--outline-dark-mode btn--lg">Start as an appointment setter →</a>
        </div>
      </div>

      <div class="vst-hero__visual">
        <div class="vst-hero__process-card">
          <div class="vst-process-step vst-process-step--active">
            <div class="vst-process-step__num">01</div>
            <div>
              <strong>Screening</strong>
              <span>We review your profile</span>
            </div>
            <div class="vst-process-step__badge vst-process-step__badge--done">✓</div>
          </div>
          <div class="vst-process-step">
            <div class="vst-process-step__num">02</div>
            <div>
              <strong>Training</strong>
              <span>CM Certified program</span>
            </div>
            <div class="vst-process-step__badge">→</div>
          </div>
          <div class="vst-process-step">
            <div class="vst-process-step__num">03</div>
            <div>
              <strong>Matching</strong>
              <span>Connected to the right company</span>
            </div>
            <div class="vst-process-step__badge">→</div>
          </div>
          <div class="vst-process-step">
            <div class="vst-process-step__num">04</div>
            <div>
              <strong>Grow</strong>
              <span>Close, learn, earn</span>
            </div>
            <div class="vst-process-step__badge">→</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAAROM CLOSERSMATCH
  ================================================ -->
  <section class="section vst-waarom">
    <div class="container">
      <div class="vst-waarom__inner">
        <div class="vst-waarom__content">
          <span class="label">Why ClosersMatch</span>
          <h2 class="h2 vst-waarom__title">Top salespeople do not lack<br />talent. They lack<br /><span class="vst-waarom__title-red">access.</span></h2>
          <p class="vst-waarom__body">Top performers stall not because they lack skill, but because they lack the right environment. No quality leads. No fair commission structures. No coaching that actually helps.</p>
          <p class="vst-waarom__body">ClosersMatch fixes that. We give you access to companies that are ready, training that makes you genuinely better, and a system that makes your results visible.</p>
        </div>

        <div class="vst-waarom__blocks">
          <div class="vst-waarom__block">
            <div class="vst-waarom__block-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <h3 class="vst-waarom__block-title">Better companies</h3>
              <p class="vst-waarom__block-text">Only vetted companies with proven offers and warm leads.</p>
            </div>
          </div>
          <div class="vst-waarom__block">
            <div class="vst-waarom__block-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <h3 class="vst-waarom__block-title">Real coaching</h3>
              <p class="vst-waarom__block-text">Conversation analysis, call reviews, and direct feedback.</p>
            </div>
          </div>
          <div class="vst-waarom__block">
            <div class="vst-waarom__block-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div>
              <h3 class="vst-waarom__block-title">Performance insight</h3>
              <p class="vst-waarom__block-text">You see what you close and what you can improve.</p>
            </div>
          </div>
          <div class="vst-waarom__block">
            <div class="vst-waarom__block-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div>
              <h3 class="vst-waarom__block-title">Community of top performers</h3>
              <p class="vst-waarom__block-text">A network of certified closers and setters.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       TWEE ROLLEN
  ================================================ -->
  <section class="section vst-rollen">
    <div class="container">
      <div class="vst-rollen__header">
        <span class="label">Choose your entry role</span>
        <h2 class="h2 vst-rollen__title">Two roles. One ecosystem.<br />You choose where you start.</h2>
        <p class="vst-rollen__sub">Whether you already have experience or are just starting out, there is a place for you at ClosersMatch.</p>
      </div>

      <div class="vst-rollen__grid">

        <div class="vst-rol-card vst-rol-card--setter">
          <div class="vst-rol-card__header">
            <span class="vst-rol-card__overline">Beginners welcome</span>
            <h3 class="vst-rol-card__title">Appointment Setter</h3>
          </div>
          <p class="vst-rol-card__body">You learn how to qualify leads, open conversations, and keep prospects warm. Real hands-on experience with real companies.</p>
          <ul class="vst-rol-card__list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              No years of sales experience required
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Paid per qualified appointment
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              CM Setter training included
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Clear path to closer available
            </li>
          </ul>
          <a href="/en/for-appointment-setters" class="btn btn--outline-red vst-rol-card__cta">Start as an appointment setter →</a>
        </div>

        <div class="vst-rol-card vst-rol-card--closer">
          <div class="vst-rol-card__badge">Most popular</div>
          <div class="vst-rol-card__header">
            <span class="vst-rol-card__overline">For experienced sales professionals</span>
            <h3 class="vst-rol-card__title">Closer</h3>
          </div>
          <p class="vst-rol-card__body">You run conversations, uncover needs, and close the deal. Warm leads, no cold calling.</p>
          <ul class="vst-rol-card__list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Warm leads, no cold calling
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Paid per closed deal
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              CM Certified badge for your profile
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Matched by industry and deal size
            </li>
          </ul>
          <a href="/en/for-closers" class="btn btn--red vst-rol-card__cta">Become a CM Certified closer →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT
  ================================================ -->
  <section class="section vst-hiw" id="hoe-het-werkt">
    <div class="container">
      <div class="vst-hiw__header">
        <span class="label">The process</span>
        <h2 class="h2 vst-hiw__title">From application to<br />your first deal.</h2>
      </div>

      <div class="vst-hiw__steps">

        <div class="vst-hiw__step">
          <div class="vst-hiw__step-left">
            <div class="vst-hiw__step-num">01</div>
            <div class="vst-hiw__step-line"></div>
          </div>
          <div class="vst-hiw__step-content">
            <h3 class="vst-hiw__step-title">Apply &amp; screening</h3>
            <p class="vst-hiw__step-text">You apply through the form. We review your background, motivation, and potential. Only suitable candidates move forward, so network quality stays high.</p>
          </div>
        </div>

        <div class="vst-hiw__step">
          <div class="vst-hiw__step-left">
            <div class="vst-hiw__step-num">02</div>
            <div class="vst-hiw__step-line"></div>
          </div>
          <div class="vst-hiw__step-content">
            <h3 class="vst-hiw__step-title">CM Certified training</h3>
            <p class="vst-hiw__step-text">Not a certificate for the wall. You learn how to steer every conversation, handle objections, and close the deal, including the tough ones. Intensive role-play, real scenarios, direct feedback.</p>
          </div>
        </div>

        <div class="vst-hiw__step">
          <div class="vst-hiw__step-left">
            <div class="vst-hiw__step-num">03</div>
            <div class="vst-hiw__step-line"></div>
          </div>
          <div class="vst-hiw__step-content">
            <h3 class="vst-hiw__step-title">Matching with a company</h3>
            <p class="vst-hiw__step-text">We connect you with a company that fits your industry, sales style, and deal size. You get clarity on the product, customer, and sales process before you start.</p>
          </div>
        </div>

        <div class="vst-hiw__step vst-hiw__step--last">
          <div class="vst-hiw__step-left">
            <div class="vst-hiw__step-num">04</div>
          </div>
          <div class="vst-hiw__step-content">
            <h3 class="vst-hiw__step-title">Close, learn &amp; grow</h3>
            <p class="vst-hiw__step-text">You get to work. Conversations are analyzed, feedback is given, and your results are tracked. Every week you get better. Every month you earn more.</p>
          </div>
        </div>

      </div>

      <div class="vst-hiw__cta">
        <a href="/en/contact" class="btn btn--red btn--lg">Apply now →</a>
      </div>
    </div>
  </section>

  <!-- ================================================
       HET ECOSYSTEEM
  ================================================ -->
  <section class="section vst-ecosystem">
    <div class="container">
      <div class="vst-ecosystem__header">
        <span class="label label--red">The CM ecosystem</span>
        <h2 class="h2 vst-ecosystem__title">More than opportunities.<br />A complete system to grow.</h2>
      </div>

      <div class="vst-ecosystem__grid">

        <div class="vst-eco-card">
          <div class="vst-eco-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="vst-eco-card__title">Qualified assignments</h3>
          <p class="vst-eco-card__text">High-ticket companies with proven products, fair commission structures, and warm leads ready to be closed.</p>
        </div>

        <div class="vst-eco-card">
          <div class="vst-eco-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="vst-eco-card__title">CM Certified training</h3>
          <p class="vst-eco-card__text">Intensive sales training built on real conversations. Role-play, scenarios, and direct feedback from experienced coaches.</p>
        </div>

        <div class="vst-eco-card">
          <div class="vst-eco-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="vst-eco-card__title">Conversation analysis &amp; coaching</h3>
          <p class="vst-eco-card__text">Every conversation is analyzed. Conversion rates, objections, timing, you see exactly what can improve and how.</p>
        </div>

        <div class="vst-eco-card">
          <div class="vst-eco-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="vst-eco-card__title">Ongoing guidance</h3>
          <p class="vst-eco-card__text">Not a one-off training and then you are on your own. Weekly coaching, reviews, and optimization for as long as you are active.</p>
        </div>

        <div class="vst-eco-card">
          <div class="vst-eco-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <h3 class="vst-eco-card__title">Performance dashboard</h3>
          <p class="vst-eco-card__text">See your pipeline, conversions, and earnings in real time. No surprises. Full control over your own performance.</p>
        </div>

        <div class="vst-eco-card">
          <div class="vst-eco-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="vst-eco-card__title">Network of top performers</h3>
          <p class="vst-eco-card__text">You become part of a community of certified closers and setters. Share knowledge. Stay sharp. Grow together.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================
       SOCIAL PROOF
  ================================================ -->
  <section class="section vst-social">
    <div class="container">
      <div class="vst-social__header">
        <span class="label">What members say</span>
        <h2 class="h2 vst-social__title">People already closing<br />for ClosersMatch.</h2>
      </div>

      <div class="vst-social__grid">

        <div class="vst-quote-card">
          <div class="vst-quote-card__stars">★★★★★</div>
          <p class="vst-quote-card__text">"I was stuck on platforms where I had to find my own leads. At ClosersMatch I got warm appointments right away and a company that was genuinely serious. €4,200 in commission in my first month."</p>
          <div class="vst-quote-card__author">
            <div class="vst-quote-card__avatar">JV</div>
            <div>
              <strong>Jeffrey V.</strong>
              <span>CM Certified Closer</span>
            </div>
          </div>
        </div>

        <div class="vst-quote-card vst-quote-card--featured">
          <div class="vst-quote-card__stars">★★★★★</div>
          <p class="vst-quote-card__text">"I had zero sales experience. Through the setter route I learned how to qualify leads and open conversations. After three months I became a closer. Now I close deals for an energy company."</p>
          <div class="vst-quote-card__author">
            <div class="vst-quote-card__avatar">MG</div>
            <div>
              <strong>Malu G.</strong>
              <span>CM Certified Closer, started as setter</span>
            </div>
          </div>
        </div>

        <div class="vst-quote-card">
          <div class="vst-quote-card__stars">★★★★★</div>
          <p class="vst-quote-card__text">"The training is not soft. You get feedback that cuts. But my conversion rate went from 22% to 58% in six weeks. That speaks for itself."</p>
          <div class="vst-quote-card__author">
            <div class="vst-quote-card__avatar">RV</div>
            <div>
              <strong>Robert V.</strong>
              <span>CM Certified Closer</span>
            </div>
          </div>
        </div>

      </div>

      <div class="vst-social__stats">
        <div class="vst-social__stat">
          <span class="vst-social__stat-num">50+</span>
          <span class="vst-social__stat-label">Successful matches</span>
        </div>
        <div class="vst-social__stat-divider"></div>
        <div class="vst-social__stat">
          <span class="vst-social__stat-num">CM</span>
          <span class="vst-social__stat-label">Certified badge, recognized mark of quality</span>
        </div>
        <div class="vst-social__stat-divider"></div>
        <div class="vst-social__stat">
          <span class="vst-social__stat-num">48u</span>
          <span class="vst-social__stat-label">Average time to first match</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AFSLUITENDE CTA
  ================================================ -->
  <section class="vst-closing">
    <div class="vst-closing__inner">
      <h2 class="vst-closing__title">
        Ready to earn serious<br />money in sales?
      </h2>
      <p class="vst-closing__body">
        ClosersMatch is not a platform for people who want to try sales.<br />
        It is an ecosystem for people who want to excel.
      </p>
      <div class="vst-closing__actions">
        <a href="/en/for-closers" class="btn btn--red btn--lg">Become a CM Certified closer →</a>
        <a href="/en/for-appointment-setters" class="btn btn--outline-white btn--lg">Start as an appointment setter →</a>
      </div>
      <p class="vst-closing__sub">Free to apply. No obligations.</p>
      <p class="vst-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .vst-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .vst-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .vst-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .vst-hero__title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .vst-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .vst-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
    letter-spacing: 0.01em;
  }

  .vst-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: nowrap;
    align-items: center;
  }

  .vst-hero__process-card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .vst-process-step {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .vst-process-step:last-of-type { border-bottom: none; }

  .vst-process-step__num {
    font-size: 0.7rem;
    font-weight: 900;
    color: var(--color-red);
    letter-spacing: 0.06em;
  }

  .vst-process-step strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2px;
  }

  .vst-process-step span {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.4;
  }

  .vst-process-step__badge {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.4);
  }

  .vst-process-step__badge--done {
    background: rgba(221,52,46,0.2);
    color: var(--color-red);
  }

  @media (max-width: 960px) {
    .vst-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .vst-hero { padding: 100px 0 60px; }
    .vst-hero__actions { flex-direction: column; align-items: stretch; }
