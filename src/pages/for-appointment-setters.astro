---
import Layout from '../layouts/Layout.astro';
---

<Layout locale="en" title="For Appointment Setters — ClosersMatch" description="Join the ClosersMatch setter network. Vetted companies, CM training, AI coaching, and assignments that fit you. You book the appointments. We handle the rest.">

  <!-- ================================================
       HERO
  ================================================ -->
  <section class="vas-hero">
    <div class="container vas-hero__inner">
      <div class="vas-hero__content">
        <span class="label label--red">For appointment setters</span>
        <h1 class="vas-hero__title">
          Open conversations.<br />
          Create opportunities.<br />
          <span class="vas-hero__title-red">Paid per appointment.</span>
        </h1>
        <p class="vas-hero__subtitle">
          ClosersMatch connects appointment setters with vetted B2B companies with proven offers. No endless prospecting. No job applications. You focus on conversations, we handle the rest.
        </p>
        <div class="vas-hero__trust-pills">
          <span class="trust-pill">✓ Paid per appointment</span>
          <span class="trust-pill">✓ Vetted companies</span>
          <span class="trust-pill">✓ CM Setter training</span>
        </div>
        <div class="vas-hero__actions">
          <a href="/contact" class="btn btn--red btn--lg">Join the network →</a>
          <a href="#hoe-het-werkt" class="btn btn--outline-dark-mode">How it works</a>
        </div>
        <p class="vas-hero__note">Only approved members get access.</p>
      </div>

      <div class="vas-hero__visual">
        <div class="vas-hero__card">
          <div class="vas-hero__card-header">
            <span class="vas-hero__card-label">Your focus as a setter</span>
          </div>
          <div class="vas-hero__card-items">
            <div class="vas-card-item vas-card-item--active">
              <div class="vas-card-item__icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Qualify leads</strong>
                <span>Only serious buyers get through</span>
              </div>
            </div>
            <div class="vas-card-item vas-card-item--active">
              <div class="vas-card-item__icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Open conversations</strong>
                <span>LinkedIn, email, and phone</span>
              </div>
            </div>
            <div class="vas-card-item vas-card-item--active">
              <div class="vas-card-item__icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Book appointments</strong>
                <span>Warm and ready for the closer</span>
              </div>
            </div>
            <div class="vas-card-item">
              <div class="vas-card-item__icon vas-card-item__icon--gray">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
              <div>
                <strong>Progress to closer</strong>
                <span>When you are ready</span>
              </div>
            </div>
          </div>
          <div class="vas-hero__card-footer">
            <span class="vas-hero__card-stat"><strong>50+</strong> matches</span>
            <span class="vas-hero__card-dot">•</span>
            <span class="vas-hero__card-stat">Paid <strong>per appointment</strong></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAAROM CLOSERSMATCH
  ================================================ -->
  <section class="section vas-waarom">
    <div class="container">
      <div class="vas-waarom__inner">
        <div class="vas-waarom__content">
          <span class="label">Why ClosersMatch</span>
          <h2 class="h2 vas-waarom__title">Most setters are<br />looking for work. Our members<br /><span class="vas-waarom__title-red">are doing it.</span></h2>
          <p class="vas-waarom__body">Endless prospecting, applying on platforms, and still waiting to see if anything comes in. That is how most appointment setters waste their time.</p>
          <p class="vas-waarom__body">At ClosersMatch you get direct access to vetted companies ready to work with you. You focus on having conversations, everything else is already handled.</p>
          <a href="/contact" class="btn btn--red">Apply now →</a>
        </div>

        <div class="vas-waarom__checklist">
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Access to vetted B2B companies</h3>
              <p class="vas-waarom__check-text">Every company in our network is screened. Serious businesses, proven offers, clear processes. No wasted time.</p>
            </div>
          </div>
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Work with proven products</h3>
              <p class="vas-waarom__check-text">You represent companies with products or services that work. No uncertainty about what you sell or who you sell to.</p>
            </div>
          </div>
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Ongoing guidance</h3>
              <p class="vas-waarom__check-text">AI coaching after every conversation, weekly feedback, and a community of sales professionals. You never stop getting better.</p>
            </div>
          </div>
          <div class="vas-waarom__check">
            <div class="vas-waarom__check-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="vas-waarom__check-title">Focus on performance, not recruiting</h3>
              <p class="vas-waarom__check-text">No time lost searching for assignments. We bring opportunities to you. You book the appointments.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       HOE HET WERKT
  ================================================ -->
  <section class="section vas-hiw" id="hoe-het-werkt">
    <div class="container">
      <div class="vas-hiw__header">
        <span class="label">The process</span>
        <h2 class="h2 vas-hiw__title">From application to<br />your first appointment.</h2>
      </div>

      <div class="vas-hiw__grid">
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">01</div>
          <h3 class="vas-hiw__step-title">Apply &amp; screening</h3>
          <p class="vas-hiw__step-text">You apply through the form. We review your motivation, communication style, and potential. Only suitable candidates move forward, so network quality stays high.</p>
        </div>
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">02</div>
          <h3 class="vas-hiw__step-title">CM Setter training</h3>
          <p class="vas-hiw__step-text">You learn how to qualify leads, open conversations via LinkedIn, email, and phone, and keep prospects warm. Hands-on training with AI feedback and real scripts for real situations.</p>
        </div>
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">03</div>
          <h3 class="vas-hiw__step-title">Matching with a company</h3>
          <p class="vas-hiw__step-text">We connect you with a company that fits your style, industry, and availability. You get clarity on the product, target audience, and approach before your first conversation.</p>
        </div>
        <div class="vas-hiw__step">
          <div class="vas-hiw__step-num">04</div>
          <h3 class="vas-hiw__step-title">Book appointments &amp; grow</h3>
          <p class="vas-hiw__step-text">You get to work. Every conversation is analyzed and feedback is given. Paid per qualified appointment. Ready for the next step? The path to closer is open.</p>
        </div>
      </div>

      <div class="vas-hiw__cta">
        <a href="/contact" class="btn btn--red btn--lg">Start as an appointment setter →</a>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAT JE LEERT
  ================================================ -->
  <section class="section vas-training">
    <div class="container">
      <div class="vas-training__inner">
        <div class="vas-training__content">
          <span class="label label--red">CM Setter training</span>
          <h2 class="h2 vas-training__title">Built for the modern appointment setter.</h2>
          <p class="vas-training__body">The world of sales is changing fast. LinkedIn, email, AI, the setter who knows how to use all these channels wins. Our training gives you exactly that.</p>
          <p class="vas-training__body">No theory. Hands-on training based on real conversations, with direct feedback and AI analysis after every touchpoint.</p>

          <div class="vas-training__skills">
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              LinkedIn outreach &amp; connection strategies
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Cold email frameworks that convert
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Lead qualification &amp; questioning
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Communication coaching &amp; tone
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              AI feedback &amp; performance insights
            </div>
            <div class="vas-training__skill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Personalized scripts per prospect
            </div>
          </div>
        </div>

        <div class="vas-training__card">
          <div class="vas-training__card-header">
            <span class="vas-training__card-badge">CM Certified Setter</span>
            <h3 class="vas-training__card-title">What you can do after training</h3>
          </div>
          <div class="vas-training__outcomes">
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">01</span>
              <p>Qualify leads on buying intent, so you never waste time on the wrong prospects</p>
            </div>
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">02</span>
              <p>Open a conversation on any channel, LinkedIn, email, or phone, in a way that gets a response</p>
            </div>
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">03</span>
              <p>Handle objections and keep prospects warm until the closer closes the deal</p>
            </div>
            <div class="vas-training__outcome">
              <span class="vas-training__outcome-num">04</span>
              <p>Track your own results and improve weekly based on data and coaching</p>
            </div>
          </div>
          <a href="/contact" class="btn btn--red vas-training__card-cta">Start your training →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       WAT JE KRIJGT (ecosystem)
  ================================================ -->
  <section class="section vas-eco">
    <div class="container">
      <div class="vas-eco__header">
        <span class="label">More than an assignment</span>
        <h2 class="h2 vas-eco__title">A complete system<br />to grow as a setter.</h2>
        <p class="vas-eco__sub">Most platforms help you find work. ClosersMatch helps you build a career.</p>
      </div>

      <div class="vas-eco__grid">
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3l-4 4-4-4"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Qualified assignments</h3>
          <p class="vas-eco-card__text">Direct access to companies actively looking for appointment setters. No endless applying or prospecting.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="vas-eco-card__title">CM Setter training</h3>
          <p class="vas-eco-card__text">Hands-on training based on real conversations. LinkedIn, cold email, phone qualification, everything is covered.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
          </div>
          <h3 class="vas-eco-card__title">AI coaching &amp; feedback</h3>
          <p class="vas-eco-card__text">Every conversation is analyzed. You get insight into your conversion rate, response time, and communication style, automatically.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Setter community</h3>
          <p class="vas-eco-card__text">An active community of certified setters and closers. Share scripts, exchange experiences, stay sharp.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Performance dashboard</h3>
          <p class="vas-eco-card__text">Real-time insight into your appointments, conversions, and earnings. You set your own pace and growth.</p>
        </div>
        <div class="vas-eco-card">
          <div class="vas-eco-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
          <h3 class="vas-eco-card__title">Path to closer</h3>
          <p class="vas-eco-card__text">When you are ready, the step up to closer is a natural next move. Not required. But possible, and guidance is ready when you are.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       AI PERFORMANCE PLATFORM
  ================================================ -->
  <section class="section vas-ai">
    <div class="container">
      <div class="vas-ai__inner">
        <div class="vas-ai__content">
          <span class="label label--red">AI Performance Platform</span>
          <h2 class="h2 vas-ai__title">Live feedback on every call.<br />Including your own.</h2>
          <p class="vas-ai__body">On top of the CM Setter training, you get access to the AI Performance Platform. Practice with AI based on different industries and objections, with live feedback during the call. When you then call a real lead, the system works exactly the same: live feedback during the conversation and an analysis afterwards.</p>
          <ul class="vas-ai__list">
            <li>✓ Insight into opening, questioning technique, listening skills &amp; objections</li>
            <li>✓ Personal scoreboard with appointment quality and conversion</li>
            <li>✓ Direct AI feedback, on top of coaching from Stefan Kelderman</li>
            <li>✓ Verified profile, visible to companies within the network</li>
          </ul>
          <a href="/academy" class="btn btn--red vas-ai__cta">Discover the Academy &amp; AI platform →</a>
        </div>
        <div class="vas-ai__visual">
          <div class="vas-ai__card">
            <div class="vas-ai__card-row"><span>Live feedback during calls</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>Analysis afterwards</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>Personal scoreboard</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>1-on-1 coaching with Stefan Kelderman</span><strong>✓</strong></div>
            <div class="vas-ai__card-row"><span>Verified profile</span><strong>✓</strong></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       CLOSING CTA
  ================================================ -->
  <section class="vas-closing">
    <div class="vas-closing__inner">
      <span class="label label--ghost-light">Limited spots available</span>
      <h2 class="vas-closing__title">
        Stop searching<br />for assignments.<br />
        <span class="vas-closing__title-red">Start booking.</span>
      </h2>
      <p class="vas-closing__body">
        ClosersMatch gives appointment setters access to the companies, training, and system to perform for real. No platforms. No cold starts. Just get to work.
      </p>
      <a href="/contact" class="btn btn--red btn--xl vas-closing__btn">Apply as a setter →</a>
      <p class="vas-closing__sub">Free to apply. Motivated appointment setters only.</p>
      <p class="vas-closing__brand">ClosersMatch. <span>The Revenue Ecosystem.</span></p>
    </div>
  </section>

</Layout>

<style>
  /* ====================================================
     HERO
  ==================================================== */
  .vas-hero {
    background: #fff;
    padding: 162px 0 80px;
  }

  .vas-hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .vas-hero__content .label--red {
    background: rgba(221,52,46,0.1);
    color: var(--color-red);
    border: 1px solid rgba(221,52,46,0.25);
  }

  .vas-hero__title {
    font-size: clamp(1.9rem, 3.6vw, 3rem);
    font-weight: 900;
    color: var(--color-black);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 20px 0 24px;
    font-family: var(--font-display);
  }

  .vas-hero__title-red { color: var(--color-red); }

  .vas-hero__subtitle {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.75;
    margin-bottom: 24px;
    max-width: 520px;
  }

  .vas-hero__trust-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-pill {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-black);
    background: var(--color-gray-light);
    border-radius: 999px;
    padding: 5px 14px;
  }

  .vas-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 16px;
  }

  .vas-hero__note {
    font-size: 0.82rem;
    color: var(--color-gray-mid);
    font-style: italic;
  }

  /* Card rechts */
  .vas-hero__card {
    background: var(--color-black);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .vas-hero__card-header {
    padding: 18px 24px;
    background: rgba(221,52,46,0.15);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .vas-hero__card-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .vas-hero__card-items {
    padding: 8px 0;
  }

  .vas-card-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 12px;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .vas-card-item:last-child { border-bottom: none; }

  .vas-card-item__icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(221,52,46,0.2);
    color: var(--color-red);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .vas-card-item__icon--gray {
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.3);
  }

  .vas-card-item strong {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2px;
  }

  .vas-card-item span {
    font-size: 0.76rem;
    color: rgba(255,255,255,0.4);
  }

  .vas-hero__card-footer {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: rgba(255,255,255,0.03);
    border-top: 1px solid rgba(255,255,255,0.07);
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  .vas-hero__card-stat strong { color: #fff; }
  .vas-hero__card-dot { color: var(--color-red); }

  @media (max-width: 960px) {
    .vas-hero__inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 560px) {
    .vas-hero { padding: 100px 0 60px; }
    .vas-hero__actions { flex-direction: column; align-items: stretch; }
    .vas-hero__actions .btn { width: 100%; justify-content: center; }
  }

  /* ====================================================
     WAAROM
  ==================================================== */
  .vas-waarom { background: #F9FAFB; }

  .vas-waarom__inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }

  .vas-waarom__title {
    margin-top: 16px;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .vas-waarom__title-red { color: var(--color-red); }

  .vas-waarom__body {
    font-size: 1rem;
    color: var(--color-gray-mid);
