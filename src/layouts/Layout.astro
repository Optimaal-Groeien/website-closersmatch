---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import type { Locale } from '../i18n/config';
import { getTranslations, getLocalizedPath, getRouteKeyFromPathname, getAlternatePath } from '../i18n/utils';

export interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}
const { title, description, locale = 'nl' } = Astro.props;
const t = getTranslations(locale);
const desc = description ?? t.meta.defaultDescription;
const homePath = getLocalizedPath('home', locale);
const currentPath = Astro.url.pathname;
const routeKey = getRouteKeyFromPathname(currentPath);
const nlHref = routeKey ? getLocalizedPath(routeKey, 'nl') : '/nl';
const enHref = routeKey ? getLocalizedPath(routeKey, 'en') : '/en';
const siteOrigin = Astro.site?.origin ?? 'https://website-closersmatch.optimaalgroeien-84d.workers.dev';
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <link rel="alternate" hreflang="nl" href={`${siteOrigin}${nlHref}`} />
    <link rel="alternate" hreflang="en" href={`${siteOrigin}${enHref}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteOrigin}/nl`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title} | ClosersMatch</title>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="header-inner">

        <!-- LINKS: rood blok — loopt over volledige hoogte van de header -->
        <a href={homePath} class="header-logo" aria-label="ClosersMatch homepage">
          <img src="/images/logo-white.png" alt="ClosersMatch" class="header-logo__img" />
        </a>

        <!-- RECHTS: twee rijen gestapeld -->
        <div class="header-right">

          <!-- Bovenste dunne balk: socials + contact -->
          <div class="header-topbar">
            <div class="header-topbar__inner">
              <div class="header-topbar__socials">
                <span class="header-topbar__follow">{t.header.followUs}</span>
                <a href="https://facebook.com/closersmatch" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://linkedin.com/company/closersmatch" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="https://instagram.com/closersmatch" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              </div>
              <div class="header-topbar__divider"></div>
              <div class="header-topbar__contact">
                <a href="mailto:info@closersmatch.nl" class="header-contact-item">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  info@closersmatch.nl
                </a>
                <a href="tel:+31634835912" class="header-contact-item">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.91 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.82 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  +31 6 3483 5912
                </a>
              </div>
            </div>
          </div>

          <!-- Onderste hoge balk: navigatie -->
          <div class="header-navbar">
            <div class="header-navbar__inner">
              <nav class="nav-links" aria-label={t.header.navLabel}>
                <div class="nav-item">
                  <span class="nav-link nav-item__label">{t.header.forBusinesses} <span class="nav-chevron">▾</span></span>
                  <div class="nav-dropdown">
                    <a href={getLocalizedPath('werkwijze', locale)} class="nav-dropdown__link">{t.header.workflow}</a>
                    <a href={getLocalizedPath('recruitment', locale)} class="nav-dropdown__link">{t.header.recruitment}</a>
                    <a href={getLocalizedPath('noCureNoPay', locale)} class="nav-dropdown__link">{t.header.noCureNoPay}</a>
                    <a href={getLocalizedPath('opdrachtPlaatsen', locale)} class="nav-dropdown__link">{t.header.placeAssignment}</a>
                  </div>
                </div>
                <div class="nav-item">
                  <a href={getLocalizedPath('voorSalesTalent', locale)} class="nav-link nav-item__label">{t.header.forSalesTalent} <span class="nav-chevron">▾</span></a>
                  <div class="nav-dropdown">
                    <a href={getLocalizedPath('voorClosers', locale)} class="nav-dropdown__link">{t.header.forClosers}</a>
                    <a href={getLocalizedPath('voorAppointmentsetters', locale)} class="nav-dropdown__link">{t.header.forAppointmentsetters}</a>
                    <a href={getLocalizedPath('recruitment', locale)} class="nav-dropdown__link">{t.header.salesRecruitment}</a>
                  </div>
                </div>
                <a href={getLocalizedPath('partnership', locale)} class="nav-link">{t.header.partnership}</a>
                <div class="nav-item">
                  <a href={getLocalizedPath('overOns', locale)} class="nav-link nav-item__label">{t.header.about} <span class="nav-chevron">▾</span></a>
                  <div class="nav-dropdown">
                    <a href={getLocalizedPath('overOns', locale)} class="nav-dropdown__link">{t.header.about}</a>
                    <a href={getLocalizedPath('cases', locale)} class="nav-dropdown__link">{t.header.casesReviews}</a>
                    <a href={getLocalizedPath('blog', locale)} class="nav-dropdown__link">{t.header.blog}</a>
                    <a href={getLocalizedPath('contact', locale)} class="nav-dropdown__link">{t.header.contact}</a>
                  </div>
                </div>
              </nav>
              <div class="nav-actions">
                <LanguageSwitcher locale={locale} currentPath={currentPath} />
                <a href="https://portal.closersmatch.com/home-visitor" class="btn btn--outline" target="_blank" rel="noopener noreferrer">{t.header.login}</a>
                <a href={getLocalizedPath('contact', locale)} class="btn btn--red">{t.header.planMeeting}</a>
              </div>
              <button class="nav-toggle" aria-label={t.header.menuOpen} id="nav-toggle">
                <span></span><span></span><span></span>
              </button>
            </div>
          </div>

        </div>
      </div>

      <!-- Mobiel menu -->
      <div class="nav-mobile" id="nav-mobile">
        <div class="nav-mobile-group">
          <button class="nav-mobile-toggle" aria-expanded="false">{t.header.forBusinesses} <span class="nav-chevron">▾</span></button>
          <div class="nav-mobile-sub">
            <a href={getLocalizedPath('werkwijze', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.workflow}</a>
            <a href={getLocalizedPath('recruitment', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.recruitment}</a>
            <a href={getLocalizedPath('noCureNoPay', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.noCureNoPay}</a>
            <a href={getLocalizedPath('opdrachtPlaatsen', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.placeAssignment}</a>
          </div>
        </div>
        <div class="nav-mobile-group">
          <button class="nav-mobile-toggle" aria-expanded="false">{t.header.forSalesTalent} <span class="nav-chevron">▾</span></button>
          <div class="nav-mobile-sub">
            <a href={getLocalizedPath('voorClosers', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.forClosers}</a>
            <a href={getLocalizedPath('voorAppointmentsetters', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.forAppointmentsetters}</a>
            <a href={getLocalizedPath('recruitment', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.salesRecruitment}</a>
          </div>
        </div>
        <a href={getLocalizedPath('partnership', locale)} class="nav-mobile-link">{t.header.partnership}</a>
        <div class="nav-mobile-group">
          <button class="nav-mobile-toggle" aria-expanded="false">{t.header.about} <span class="nav-chevron">▾</span></button>
          <div class="nav-mobile-sub">
            <a href={getLocalizedPath('overOns', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.about}</a>
            <a href={getLocalizedPath('cases', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.casesReviews}</a>
            <a href={getLocalizedPath('blog', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.blog}</a>
            <a href={getLocalizedPath('contact', locale)} class="nav-mobile-link nav-mobile-link--sub">{t.header.contact}</a>
          </div>
        </div>
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
        <a href="https://portal.closersmatch.com/home-visitor" class="btn btn--outline" style="margin-top: 8px;" target="_blank" rel="noopener noreferrer">{t.header.login}</a>
        <a href={getLocalizedPath('contact', locale)} class="btn btn--red" style="margin-top: 8px;">{t.header.planMeeting}</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <a href={homePath} class="logo">
            <img src="/images/logo-white.png" alt="ClosersMatch" class="logo__img logo__img--footer" />
          </a>
          <p class="footer-tagline">{t.footer.tagline}</p>
        </div>

        <div class="footer-links-group">
          <h4 class="footer-heading">{t.footer.forBusinesses}</h4>
          <a href={getLocalizedPath('voorBedrijven', locale)}>{t.footer.howItWorks}</a>
          <a href={getLocalizedPath('noCureNoPay', locale)}>{t.footer.noCureNoPay}</a>
          <a href={getLocalizedPath('cases', locale)}>{t.footer.casesResults}</a>
          <a href={getLocalizedPath('contact', locale)}>{t.footer.startIntake}</a>
        </div>

        <div class="footer-links-group">
          <h4 class="footer-heading">{t.footer.forClosers}</h4>
          <a href={getLocalizedPath('voorClosers', locale)}>{t.footer.becomeCloser}</a>
          <a href={getLocalizedPath('voorAppointmentsetters', locale)}>{t.footer.becomeSetter}</a>
          <a href={getLocalizedPath('overOns', locale)}>{t.footer.about}</a>
          <a href={getLocalizedPath('blog', locale)}>{t.footer.blog}</a>
        </div>

        <div class="footer-links-group">
          <h4 class="footer-heading">{t.footer.contactHeading}</h4>
          <a href={getLocalizedPath('contact', locale)}>{t.footer.getInTouch}</a>
          <a href="https://linkedin.com/company/closersmatch" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://instagram.com/closersmatch" target="_blank" rel="noopener noreferrer">Instagram</a>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="container footer-bottom-inner">
          <p>&copy; {new Date().getFullYear()} ClosersMatch. {t.footer.rights}</p>
          <div class="footer-legal">
            <a href={getLocalizedPath('contact', locale)}>{t.footer.privacy}</a>
            <a href={getLocalizedPath('contact', locale)}>{t.footer.terms}</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('nav-mobile');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  toggle?.addEventListener('click', () => {
    mobileNav?.classList.toggle('open');
    toggle?.classList.toggle('active');
  });

  document.querySelectorAll('.nav-mobile-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.nav-mobile-group');
      const isOpen = group?.classList.contains('open');
      document.querySelectorAll('.nav-mobile-group.open').forEach((g) => g.classList.remove('open'));
      if (!isOpen) group?.classList.add('open');
    });
  });
</script>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ——— Header ——— */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(0,0,0,0.10);
    transition: box-shadow 0.3s;
  }

  .site-header.scrolled {
    box-shadow: 0 4px 24px rgba(0,0,0,0.16);
  }

  /* Wrapper: logo-kolom links + twee rijen rechts */
  .header-inner {
    display: flex;
    align-items: stretch;
    position: relative;
    overflow: visible;
  }

  /* ——— Rode logo kolom: volledige hoogte ——— */
  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-red);
    width: 432px;        /* 240px × 1.8 */
    flex-shrink: 0;
    text-decoration: none;
    position: relative;
    z-index: 2;
  }

  /* Driehoek die de diagonaal naadloos verbindt met grijs/wit vlak */
  .header-logo::after {
    content: '';
    position: absolute;
    top: 0;
    left: 100%;
    width: 72px;
    height: 100%;        /* Altijd exact de volledige hoogte van het rode blok */
    background: var(--color-red);
    clip-path: polygon(0 0, 0 100%, 100% 100%);
    pointer-events: none;
    z-index: 2;
  }

  .header-logo__img {
    height: 68px;        /* 52px × 1.3 */
    width: auto;
    display: block;
    mix-blend-mode: screen;
  }

  /* ——— Rechterkant: twee rijen ——— */
  .header-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  /* Bovenste dunne balk: socials + contact */
  .header-topbar {
    background: #efefef;
    /* Geen border — dit veroorzaakte een zichtbare lijn door de diagonaal */
  }

  .header-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
    padding: 0 28px;
    height: 52px;        /* 40px × 1.3 */
  }

  .header-topbar__socials {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-topbar__follow {
    font-size: 0.72rem;
    font-weight: 700;
    color: #777;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 4px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-red);
    color: #fff;
    transition: background 0.2s, transform 0.2s;
  }

  .social-icon:hover {
    background: var(--color-red-dark);
    transform: scale(1.1);
  }

  .header-topbar__divider {
    width: 1px;
    height: 16px;
    background: #ccc;
    margin: 0 18px;
  }

  .header-topbar__contact {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .header-contact-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }

  .header-contact-item:hover { color: var(--color-red); }
  .header-contact-item svg { flex-shrink: 0; color: var(--color-red); }

  /* Onderste hoge balk: navigatie */
  .header-navbar {
    background: #fff;
    flex: 1;
  }

  .header-navbar__inner {
    display: flex;
    align-items: center;
    height: 86px;        /* 66px × 1.3 */
    padding: 0 28px 0 88px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    flex: 1;
  }

  .nav-link {
    color: var(--color-text);
    font-size: 0.93rem;
    font-weight: 500;
    transition: color 0.2s;
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 0; height: 2px;
    background: var(--color-red);
    transition: width 0.2s;
  }

  .nav-link:hover { color: var(--color-red); }
  .nav-link:hover::after { width: 100%; }

  .nav-actions { display: flex; align-items: center; gap: 12px; }

  /* ——— Dropdown nav items ——— */
  .nav-item {
    position: relative;
    display: inline-block;
  }

  .nav-item__label {
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }

  .nav-chevron {
    font-size: 0.75em;
    margin-left: 3px;
    display: inline-block;
    transition: transform 0.2s;
  }

  .nav-item:hover .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    background: #fff;
    border: 1px solid var(--color-gray-border);
    border-radius: var(--radius-lg, 10px);
    box-shadow: var(--shadow-lg, 0 8px 32px rgba(0,0,0,0.12));
    min-width: 200px;
    padding: 8px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    z-index: 200;
  }

  .nav-item:hover .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown__link {
    display: block;
    padding: 10px 20px;
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .nav-dropdown__link:hover {
    background: var(--color-gray-light, #f5f5f5);
    color: var(--color-red);
  }

  /* ——— Inloggen outline button ——— */
  .btn--outline {
    background: transparent;
    border: 2px solid var(--color-red);
    color: var(--color-red);
    transition: background 0.2s, color 0.2s;
  }

  .btn--outline:hover {
    background: rgba(var(--color-red-rgb, 220, 38, 38), 0.08);
    color: var(--color-red);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 24px; height: 2px;
    background: var(--color-black);
    border-radius: 2px;
    transition: all 0.25s;
  }

  .nav-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .nav-toggle.active span:nth-child(2) { opacity: 0; }
  .nav-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* Mobiel menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 16px 24px 24px;
