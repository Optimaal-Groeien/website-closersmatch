---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'ClosersMatch — Dé plek voor high ticket sales. Wij koppelen bedrijven met gecertificeerde closers en appointment setters.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title} | ClosersMatch</title>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="header-inner">

        <!-- LINKS: rood blok — loopt over volledige hoogte van de header -->
        <a href="/" class="header-logo" aria-label="ClosersMatch homepage">
          <img src="/images/logo-white.png" alt="ClosersMatch" class="header-logo__img" />
        </a>

        <!-- RECHTS: twee rijen gestapeld -->
        <div class="header-right">

          <!-- Bovenste dunne balk: socials + contact -->
          <div class="header-topbar">
            <div class="header-topbar__inner">
              <div class="header-topbar__socials">
                <span class="header-topbar__follow">Volg ons:</span>
                <a href="https://facebook.com/closersmatch" target="_blank" rel="noopener" aria-label="Facebook" class="social-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://linkedin.com/company/closersmatch" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="https://instagram.com/closersmatch" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              </div>
              <div class="header-topbar__divider"></div>
              <div class="header-topbar__contact">
                <a href="mailto:info@closersmatch.nl" class="header-contact-item">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  info@closersmatch.nl
                </a>
                <a href="tel:+31634835912" class="header-contact-item">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.91 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.82 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  +31 6 3483 5912
                </a>
              </div>
            </div>
          </div>

          <!-- Onderste hoge balk: navigatie -->
          <div class="header-navbar">
            <div class="header-navbar__inner">
              <nav class="nav-links" aria-label="Hoofdnavigatie">
                <a href="/voor-bedrijven" class="nav-link">Voor Bedrijven</a>
                <a href="/voor-closers" class="nav-link">Voor Closers</a>
                <a href="/cases" class="nav-link">Cases</a>
                <a href="/over-ons" class="nav-link">Over Ons</a>
                <a href="/contact" class="nav-link">Contact</a>
              </nav>
              <div class="nav-actions">
                <a href="/contact" class="btn btn--red">Gesprek Plannen →</a>
              </div>
              <button class="nav-toggle" aria-label="Menu openen" id="nav-toggle">
                <span></span><span></span><span></span>
              </button>
            </div>
          </div>

        </div>
      </div>

      <!-- Mobiel menu -->
      <div class="nav-mobile" id="nav-mobile">
        <a href="/voor-bedrijven" class="nav-mobile-link">Voor Bedrijven</a>
        <a href="/voor-closers" class="nav-mobile-link">Voor Closers</a>
        <a href="/cases" class="nav-mobile-link">Cases</a>
        <a href="/over-ons" class="nav-mobile-link">Over Ons</a>
        <a href="/contact" class="nav-mobile-link">Contact</a>
        <a href="/contact" class="btn btn--red" style="margin-top: 8px;">Gesprek Plannen →</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <a href="/" class="logo">
            <img src="/images/logo-white.png" alt="ClosersMatch" class="logo__img logo__img--footer" />
          </a>
          <p class="footer-tagline">Dé plek voor high ticket sales — voor bedrijven en closers.</p>
        </div>

        <div class="footer-links-group">
          <h4 class="footer-heading">Voor Bedrijven</h4>
          <a href="/voor-bedrijven">Hoe het werkt</a>
          <a href="/no-cure-no-pay">No Cure No Pay</a>
          <a href="/cases">Cases & Resultaten</a>
          <a href="/contact">Intake starten</a>
        </div>

        <div class="footer-links-group">
          <h4 class="footer-heading">Voor Closers</h4>
          <a href="/voor-closers">Closer worden</a>
          <a href="/appointment-setter-worden">Appointment Setter worden</a>
          <a href="/over-ons">Over ClosersMatch</a>
        </div>

        <div class="footer-links-group">
          <h4 class="footer-heading">Contact</h4>
          <a href="/contact">Contact opnemen</a>
          <a href="https://linkedin.com/company/closersmatch" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://instagram.com/closersmatch" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="container footer-bottom-inner">
          <p>&copy; {new Date().getFullYear()} ClosersMatch. Alle rechten voorbehouden.</p>
          <div class="footer-legal">
            <a href="/privacybeleid">Privacybeleid</a>
            <a href="/algemene-voorwaarden">Algemene Voorwaarden</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('nav-mobile');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  toggle?.addEventListener('click', () => {
    mobileNav?.classList.toggle('open');
    toggle?.classList.toggle('active');
  });
</script>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ——— Header ——— */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(0,0,0,0.10);
    transition: box-shadow 0.3s;
  }

  .site-header.scrolled {
    box-shadow: 0 4px 24px rgba(0,0,0,0.16);
  }

  /* Wrapper: logo-kolom links + twee rijen rechts */
  .header-inner {
    display: flex;
    align-items: stretch;
    position: relative;
    overflow: visible;
  }

  /* ——— Rode logo kolom: volledige hoogte ——— */
  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-red);
    width: 432px;        /* 240px × 1.8 */
    flex-shrink: 0;
    text-decoration: none;
    position: relative;
    z-index: 2;
  }

  /* Driehoek die de diagonaal naadloos verbindt met grijs/wit vlak */
  .header-logo::after {
    content: '';
    position: absolute;
    top: 0;
    left: 100%;
    width: 72px;
    height: 142px;       /* topbar (52px) + navbar (86px) + 4px buffer */
    background: var(--color-red);
    clip-path: polygon(0 0, 0 100%, 100% 100%);
    pointer-events: none;
    z-index: 2;
  }

  .header-logo__img {
    height: 68px;        /* 52px × 1.3 */
    width: auto;
    display: block;
    mix-blend-mode: screen;
  }

  /* ——— Rechterkant: twee rijen ——— */
  .header-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  /* Bovenste dunne balk: socials + contact */
  .header-topbar {
    background: #efefef;
    border-bottom: 1px solid var(--color-gray-border);
  }

  .header-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
    padding: 0 28px;
    height: 52px;        /* 40px × 1.3 */
  }

  .header-topbar__socials {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-topbar__follow {
    font-size: 0.72rem;
    font-weight: 700;
    color: #777;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 4px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-red);
    color: #fff;
    transition: background 0.2s, transform 0.2s;
  }

  .social-icon:hover {
    background: var(--color-red-dark);
    transform: scale(1.1);
  }

  .header-topbar__divider {
    width: 1px;
    height: 16px;
    background: #ccc;
    margin: 0 18px;
  }

  .header-topbar__contact {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .header-contact-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }

  .header-contact-item:hover { color: var(--color-red); }
  .header-contact-item svg { flex-shrink: 0; color: var(--color-red); }

  /* Onderste hoge balk: navigatie */
  .header-navbar {
    background: #fff;
    flex: 1;
  }

  .header-navbar__inner {
    display: flex;
    align-items: center;
    height: 86px;        /* 66px × 1.3 */
    padding: 0 28px 0 88px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    flex: 1;
  }

  .nav-link {
    color: var(--color-text);
    font-size: 0.93rem;
    font-weight: 500;
    transition: color 0.2s;
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 0; height: 2px;
    background: var(--color-red);
    transition: width 0.2s;
  }

  .nav-link:hover { color: var(--color-red); }
  .nav-link:hover::after { width: 100%; }

  .nav-actions { display: flex; align-items: center; gap: 12px; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 24px; height: 2px;
    background: var(--color-black);
    border-radius: 2px;
    transition: all 0.25s;
  }

  .nav-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .nav-toggle.active span:nth-child(2) { opacity: 0; }
  .nav-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* Mobiel menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 16px 24px 24px;
    background: #fff;
    border-top: 1px solid var(--color-gray-border);
  }

  .nav-mobile.open { display: flex; }

  .nav-mobile-link {
    color: var(--color-text);
    font-size: 1.05rem;
    font-weight: 500;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-gray-border);
  }

  /* White logo in footer */
  .logo__img--footer {
    mix-blend-mode: screen;
    height: 40px;
    width: auto;
    display: block;
  }

  @media (max-width: 900px) {
    .header-topbar__contact,
    .header-topbar__divider { display: none; }
    .nav-links, .nav-actions { display: none; }
    .nav-toggle { display: flex; }
  }

  @media (max-width: 600px) {
    .header-topbar__follow { display: none; }
    .header-logo { padding: 0 56px 0 20px; }
    .header-logo__img { height: 40px; }
  }

  /* ——— Footer ——— */
  .site-footer {
    background: var(--color-black);
    color: rgba(255,255,255,0.65);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding: 72px 24px 48px;
  }

  .footer-brand { display: flex; flex-direction: column; gap: 16px; }

  .footer-tagline {
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 280px;
    color: rgba(255,255,255,0.5);
  }

  .footer-links-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-heading {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 4px;
  }

  .footer-links-group a {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s;
  }

  .footer-links-group a:hover { color: #fff; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.35);
  }

  .footer-legal { display: flex; gap: 24px; }
  .footer-legal a { color: rgba(255,255,255,0.35); transition: color 0.2s; }
  .footer-legal a:hover { color: rgba(255,255,255,0.7); }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom-inner { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
